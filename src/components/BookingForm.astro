---
import { SITE_CONFIG } from '../config';

/**
 * Booking inquiry form. Static-host friendly: submission composes a structured
 * email to Marlon. Swap FORM_ENDPOINT for a Cloudflare Worker URL to capture
 * submissions in D1 instead — the payload shape stays the same.
 */
interface Props {
	heading?: string;
	kind?: 'speaking' | 'workshop' | 'general';
}

const { heading = 'Start the conversation', kind = 'general' } = Astro.props;

const inquiryTypes = [
	'Executive Keynote',
	'Conference Speaking',
	'Corporate Workshop',
	'Leadership Retreat',
	'Enterprise AI Education',
	'Advisory',
	'Podcast Interview',
	'Media Inquiry',
	'Other',
];

const defaultType =
	kind === 'speaking' ? 'Executive Keynote' : kind === 'workshop' ? 'Corporate Workshop' : '';
---

<form
	id="booking-form"
	class="reveal mx-auto max-w-2xl rounded-2xl bg-paper p-8 text-ink shadow-xl md:p-10"
	data-booking-form
	data-email={SITE_CONFIG.email}
>
	<h3 class="font-display text-2xl font-semibold">{heading}</h3>
	<p class="mt-2 text-sm text-slate">
		Every inquiry gets a personal reply — usually within 2–3 business days.
	</p>

	{/* Honeypot — offscreen, tab-skipped; humans never see or fill it */}
	<div class="absolute -left-[9999px] h-px w-px overflow-hidden" aria-hidden="true">
		<label for="bf-website">Website</label>
		<input id="bf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
	</div>

	<div class="mt-8 grid gap-6 md:grid-cols-2">
		<div>
			<label for="bf-name" class="block text-sm font-semibold">Name *</label>
			<input
				id="bf-name"
				name="name"
				type="text"
				required
				autocomplete="name"
				class="mt-2 w-full rounded-lg border border-ink/20 bg-white px-4 py-3 text-sm focus:border-emerald"
			/>
		</div>
		<div>
			<label for="bf-email" class="block text-sm font-semibold">Email *</label>
			<input
				id="bf-email"
				name="email"
				type="email"
				required
				autocomplete="email"
				class="mt-2 w-full rounded-lg border border-ink/20 bg-white px-4 py-3 text-sm focus:border-emerald"
			/>
		</div>
		<div>
			<label for="bf-org" class="block text-sm font-semibold">Organization</label>
			<input
				id="bf-org"
				name="organization"
				type="text"
				autocomplete="organization"
				class="mt-2 w-full rounded-lg border border-ink/20 bg-white px-4 py-3 text-sm focus:border-emerald"
			/>
		</div>
		<div>
			<label for="bf-type" class="block text-sm font-semibold">What do you need? *</label>
			<select
				id="bf-type"
				name="inquiryType"
				required
				class="mt-2 w-full rounded-lg border border-ink/20 bg-white px-4 py-3 text-sm focus:border-emerald"
			>
				<option value="" disabled selected={!defaultType}>Select one…</option>
				{
					inquiryTypes.map((t) => (
						<option value={t} selected={t === defaultType}>
							{t}
						</option>
					))
				}
			</select>
		</div>
		<div>
			<label for="bf-date" class="block text-sm font-semibold">Target date</label>
			<input
				id="bf-date"
				name="targetDate"
				type="text"
				placeholder="e.g. October 2026"
				class="mt-2 w-full rounded-lg border border-ink/20 bg-white px-4 py-3 text-sm focus:border-emerald"
			/>
		</div>
		<div>
			<label for="bf-audience" class="block text-sm font-semibold">Audience size</label>
			<input
				id="bf-audience"
				name="audienceSize"
				type="text"
				placeholder="e.g. 250 attendees"
				class="mt-2 w-full rounded-lg border border-ink/20 bg-white px-4 py-3 text-sm focus:border-emerald"
			/>
		</div>
		<div class="md:col-span-2">
			<label for="bf-message" class="block text-sm font-semibold">Tell Marlon about the moment you're planning *</label>
			<textarea
				id="bf-message"
				name="message"
				rows="5"
				required
				class="mt-2 w-full rounded-lg border border-ink/20 bg-white px-4 py-3 text-sm focus:border-emerald"
			></textarea>
		</div>
	</div>

	<button
		type="submit"
		class="mt-8 w-full cursor-pointer rounded-full bg-ink px-8 py-4 font-semibold text-paper transition-colors hover:bg-emerald-deep"
	>
		Send inquiry
	</button>
	<p class="mt-3 text-center text-xs text-slate" data-form-note>
		Securely stored and forwarded to {SITE_CONFIG.email}.
	</p>
</form>

<script>
	// Submissions are stored in Supabase and email-forwarded by the
	// submit-inquiry edge function; mailto remains as an offline fallback.
	import { submitInquiry } from '../lib/backend';

	for (const form of document.querySelectorAll<HTMLFormElement>('[data-booking-form]')) {
		// Fill-time tracking: sub-human submit times get spam-flagged server-side
		const startedAt = Date.now();
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!form.reportValidity()) return;
			const data = new FormData(form);
			const type = String(data.get('inquiryType') || 'Inquiry');
			const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
			if (button) {
				button.disabled = true;
				button.textContent = 'Sending…';
			}
			try {
				await submitInquiry({
					intent: type,
					name: String(data.get('name') || ''),
					email: String(data.get('email') || ''),
					organization: String(data.get('organization') || '') || undefined,
					answers: {
						'Target date': String(data.get('targetDate') || '—'),
						'Audience size': String(data.get('audienceSize') || '—'),
						Message: String(data.get('message') || ''),
					},
					website: String(data.get('website') || '') || undefined,
					elapsedMs: Date.now() - startedAt,
				});
				form.innerHTML = `
					<h3 class="font-display text-2xl font-semibold">Sent ✓</h3>
					<p class="mt-2 text-sm text-slate">Your ${type} inquiry is in — expect a personal reply within 2–3 business days.</p>`;
			} catch {
				const lines = [
					`Name: ${data.get('name')}`,
					`Email: ${data.get('email')}`,
					`Organization: ${data.get('organization') || '—'}`,
					`Inquiry type: ${type}`,
					`Target date: ${data.get('targetDate') || '—'}`,
					`Audience size: ${data.get('audienceSize') || '—'}`,
					'',
					`${data.get('message')}`,
				];
				const subject = encodeURIComponent(`[marlonavery.com] ${type} inquiry`);
				window.location.href = `mailto:${form.dataset.email}?subject=${subject}&body=${encodeURIComponent(lines.join('\n'))}`;
				if (button) {
					button.disabled = false;
					button.textContent = 'Send inquiry';
				}
			}
		});
	}
</script>
