---
interface Props {
	title: string;
	date: Date;
	endDate?: Date;
	type: string;
	city?: string;
	venue?: string;
	description: string;
	recap?: string;
	upcoming?: boolean;
}

const { title, date, endDate, type, city, venue, description, recap, upcoming = false } = Astro.props;

const fmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const dateLabel = endDate ? `${fmt.format(date)} – ${fmt.format(endDate)}` : fmt.format(date);
const location = [venue, city].filter(Boolean).join(' · ');

const typeLabels: Record<string, string> = {
	keynote: 'Keynote',
	workshop: 'Workshop',
	panel: 'Panel',
	conference: 'Conference',
	podcast: 'Podcast',
	meetup: 'Meetup',
	live: 'Live Session',
};
---

<article
	class:list={[
		'reveal rounded-2xl border p-8',
		upcoming ? 'border-emerald/40 bg-paper shadow-lg' : 'border-ink/10 bg-cream',
	]}
>
	<div class="flex flex-wrap items-center gap-3 text-sm">
		<span
			class:list={[
				'rounded-full px-3 py-1 text-xs font-semibold',
				upcoming ? 'bg-emerald text-ink' : 'bg-ink/8 text-slate',
			]}
		>
			{typeLabels[type] ?? type}
		</span>
		<time datetime={date.toISOString().slice(0, 10)} class="font-medium text-slate">{dateLabel}</time>
		{location && <span class="text-slate">· {location}</span>}
	</div>
	<h3 class="mt-4 font-display text-2xl font-semibold">{title}</h3>
	<p class="mt-3 leading-relaxed text-slate">{description}</p>
	{
		recap && (
			<p class="mt-4 border-l-2 border-emerald/40 pl-4 text-sm leading-relaxed text-slate">
				<span class="font-semibold text-ink">Recap: </span>
				{recap}
			</p>
		)
	}
</article>
