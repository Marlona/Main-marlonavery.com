---
import { FOOTER_LINKS, SITE_CONFIG, SOCIAL_LINKS } from '../config';

const year = new Date().getFullYear();
---

<footer class="theme-fixed bg-ink text-paper">
	<div class="mx-auto max-w-7xl px-6 py-20">
		<div class="grid gap-12 md:grid-cols-3">
			<div>
				<p class="text-display-sm">Building AI.<br />Teaching the Future.</p>
				<a
					href={SOCIAL_LINKS.email}
					class="mt-6 inline-block text-lg text-emerald-glow underline-offset-4 hover:underline"
				>
					{SITE_CONFIG.email}
				</a>
			</div>

			<nav aria-label="Footer">
				<h2 class="text-eyebrow text-mist">Explore</h2>
				<ul class="mt-4 space-y-3">
					{
						FOOTER_LINKS.map((link) => (
							<li>
								<a href={link.href} class="text-sm text-paper/80 transition-colors hover:text-emerald-glow">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</nav>

			<div>
				<h2 class="text-eyebrow text-mist">Elsewhere</h2>
				<ul class="mt-4 space-y-3">
					<li>
						<a href={SOCIAL_LINKS.linkedin} rel="noopener" class="text-sm text-paper/80 transition-colors hover:text-emerald-glow">
							LinkedIn
						</a>
					</li>
					<li>
						<a href={SOCIAL_LINKS.github} rel="noopener" class="text-sm text-paper/80 transition-colors hover:text-emerald-glow">
							GitHub
						</a>
					</li>
					<li>
						<a href={SOCIAL_LINKS.twitter} rel="noopener" class="text-sm text-paper/80 transition-colors hover:text-emerald-glow">
							X / Twitter
						</a>
					</li>
				</ul>
			</div>
		</div>

		<p class="mt-16 border-t border-charcoal pt-8 text-xs text-mist">
			© {year} {SITE_CONFIG.name}. Build. Learn. Teach. Inspire.
		</p>
	</div>
</footer>
