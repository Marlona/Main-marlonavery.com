---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface GalleryImage {
	src: ImageMetadata;
	alt: string;
	caption?: string;
	span?: boolean;
}

interface Props {
	images: GalleryImage[];
}

const { images } = Astro.props;
---

<ul class="grid gap-4 md:grid-cols-3">
	{
		images.map((img) => (
			<li class:list={['reveal', img.span && 'md:col-span-2 md:row-span-2']}>
				<figure class="group h-full overflow-hidden rounded-2xl">
					<Image
						src={img.src}
						alt={img.alt}
						widths={[480, 800, 1200]}
						sizes="(max-width: 768px) 100vw, 33vw"
						class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
					/>
					{img.caption && <figcaption class="sr-only">{img.caption}</figcaption>}
				</figure>
			</li>
		))
	}
</ul>
