---
import { NAV_LINKS, SITE_CONFIG } from '../config';

interface Props {
	darkHero?: boolean;
}

const { darkHero = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
	class:list={[
		'fixed inset-x-0 top-0 z-50 transition-colors duration-300',
		darkHero ? 'theme-fixed text-paper' : 'bg-paper/85 text-ink backdrop-blur-md',
	]}
	data-nav
	data-dark-hero={darkHero ? 'true' : 'false'}
>
	<div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
		<a href="/" class="text-eyebrow tracking-[0.2em]">
			{SITE_CONFIG.shortName}
		</a>

		<nav aria-label="Primary">
			<ul class="hidden items-center gap-8 md:flex">
				{
					NAV_LINKS.map((link) => (
						<li>
							<a
								href={link.href}
								aria-current={currentPath === link.href ? 'page' : undefined}
								class:list={[
									'text-sm font-medium transition-opacity hover:opacity-70',
									currentPath === link.href && 'underline decoration-emerald decoration-2 underline-offset-8',
								]}
							>
								{link.label}
							</a>
						</li>
					))
				}
				<li>
					<a
						href="/book"
						class="rounded-full bg-emerald px-5 py-2.5 text-sm font-semibold text-ink transition-transform hover:scale-105"
					>
						Book Marlon
					</a>
				</li>
				<li>
					<button
						type="button"
						data-theme-toggle
						aria-label="Switch between light and dark mode"
						class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border border-current/25 text-base transition-transform hover:scale-110"
					>
						<span data-theme-icon aria-hidden="true">☾</span>
					</button>
				</li>
			</ul>

			<details class="relative md:hidden" data-mobile-menu>
				<summary
					class="flex cursor-pointer list-none items-center gap-2 rounded px-2 py-1 text-sm font-semibold [&::-webkit-details-marker]:hidden"
					aria-label="Open navigation menu"
				>
					Menu
				</summary>
				<ul class="absolute right-0 mt-3 w-56 rounded-xl bg-ink p-4 text-paper shadow-2xl">
					{
						NAV_LINKS.map((link) => (
							<li>
								<a
									href={link.href}
									aria-current={currentPath === link.href ? 'page' : undefined}
									class="block rounded px-3 py-2.5 text-sm font-medium hover:bg-graphite"
								>
									{link.label}
								</a>
							</li>
						))
					}
					<li class="mt-2 border-t border-charcoal pt-3">
						<a href="/book" class="block rounded-full bg-emerald px-4 py-2.5 text-center text-sm font-semibold text-ink">
							Book Marlon
						</a>
					</li>
					<li class="mt-3">
						<button
							type="button"
							data-theme-toggle
							aria-label="Switch between light and dark mode"
							class="w-full cursor-pointer rounded-full border border-paper/30 px-4 py-2 text-sm font-medium"
						>
							<span data-theme-icon aria-hidden="true">☾</span> Light / dark
						</button>
					</li>
				</ul>
			</details>
		</nav>
	</div>
</header>

<script>
	// On dark-hero pages the nav floats transparent, then gains an ink backdrop after scroll.
	const nav = document.querySelector('[data-nav]');
	if (nav instanceof HTMLElement && nav.dataset.darkHero === 'true') {
		const onScroll = () => {
			nav.classList.toggle('bg-ink/85', window.scrollY > 24);
			nav.classList.toggle('backdrop-blur-md', window.scrollY > 24);
		};
		onScroll();
		window.addEventListener('scroll', onScroll, { passive: true });
	}

	// Light/dark theme toggle — persisted, applied on <html data-theme>
	const applyIcon = () => {
		const dark = document.documentElement.dataset.theme === 'dark';
		document.querySelectorAll('[data-theme-icon]').forEach((el) => {
			el.textContent = dark ? '☀' : '☾';
		});
	};
	document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
			document.documentElement.dataset.theme = next;
			localStorage.setItem('theme', next);
			applyIcon();
		});
	});
	applyIcon();
</script>
