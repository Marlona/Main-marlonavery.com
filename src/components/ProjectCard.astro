---
import { TRUSTED_BRANDS } from '../data/trustedBy';

interface Props {
	href: string;
	title: string;
	description: string;
	impact?: string;
	/** Partner org name — rendered as "In partnership with" + the brand wordmark */
	partner?: string;
	tech?: string[];
	date?: Date;
	/** Video file URL — "Watch video" opens it in an in-page popup player */
	videoSrc?: string;
	videoPoster?: string;
	/** Accessible name of the popup, e.g. "The A.I. × Library Project recap" */
	videoTitle?: string;
	tone?: 'light' | 'dark';
}

const {
	href,
	title,
	description,
	impact,
	partner,
	tech = [],
	date,
	videoSrc,
	videoPoster,
	videoTitle = 'Project film',
	tone = 'dark',
} = Astro.props;
const partnerBrand = partner ? TRUSTED_BRANDS.find((b) => b.name === partner) : undefined;
const dateLabel = date
	? new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(date)
	: undefined;
---

<article
	class:list={[
		'reveal group relative flex h-full flex-col rounded-2xl p-8 transition-transform duration-300 hover:-translate-y-1',
		tone === 'dark' ? 'bg-graphite text-paper hover:bg-charcoal' : 'bg-cream text-ink hover:bg-paper',
	]}
>
	<div class="flex items-baseline justify-between gap-4">
		<h3 class="font-display text-2xl font-semibold group-hover:text-emerald-glow">{title}</h3>
		{dateLabel && <p class:list={['shrink-0 text-xs font-semibold tracking-wide uppercase', tone === 'dark' ? 'text-mist' : 'text-slate']}>{dateLabel}</p>}
	</div>
	<p class:list={['mt-3 leading-relaxed', tone === 'dark' ? 'text-paper/70' : 'text-slate']}>{description}</p>
	{impact && <p class="mt-4 text-sm font-semibold text-emerald-glow">{impact}</p>}
	{
		partner && (
			<p class="mt-4 flex flex-wrap items-center gap-2.5">
				<span class:list={['text-xs font-semibold tracking-wide uppercase', tone === 'dark' ? 'text-paper/60' : 'text-slate']}>
					In partnership with
				</span>
				<span
					class="rounded-lg bg-paper px-3 py-1.5 font-display text-base font-semibold tracking-tight"
					style={partnerBrand?.letters ? undefined : `color: ${partnerBrand?.color ?? '#141414'}`}
				>
					{partnerBrand?.letters
						? partner
								.split('')
								.map((ch, i) => <span style={`color: ${partnerBrand.letters![i % partnerBrand.letters!.length]}`}>{ch}</span>)
						: partner}
				</span>
			</p>
		)
	}
	{
		tech.length > 0 && (
			<ul class="mt-6 flex flex-wrap gap-2" aria-label="Tech stack and AI models">
				{tech.slice(0, 6).map((t) => (
					<li
						class:list={[
							'rounded-full px-3 py-1 text-xs font-medium',
							tone === 'dark' ? 'bg-ink text-mist' : 'bg-paper text-slate',
						]}
					>
						{t}
					</li>
				))}
			</ul>
		)
	}
	<div class="mt-auto flex flex-wrap gap-3 pt-8">
		<a
			href={href}
			class:list={[
				'relative z-10 inline-block rounded-full px-5 py-2.5 text-sm font-bold transition-transform group-hover:scale-105',
				tone === 'dark' ? 'bg-emerald text-ink' : 'bg-ink text-paper',
			]}
		>
			Case study →<span class="sr-only"> for {title}</span>
		</a>
		{
			videoSrc && (
				<>
					<button
						type="button"
						data-video-trigger
						class:list={[
							'relative z-10 inline-block cursor-pointer rounded-full border px-5 py-2.5 text-sm font-bold transition-colors',
							tone === 'dark'
								? 'border-paper/30 text-paper hover:border-emerald-glow hover:text-emerald-glow'
								: 'border-ink/25 text-ink hover:border-emerald-deep hover:text-emerald-deep',
						]}
					>
						Watch video ▸<span class="sr-only"> — {videoTitle}</span>
					</button>
					{/* Popup player — native <dialog> in the top layer; Esc, ✕, and backdrop all close it */}
					<dialog
						data-video-modal
						aria-label={videoTitle}
						class="m-auto w-[min(96vw,64rem)] rounded-2xl bg-ink p-0 backdrop:bg-ink/80 backdrop:backdrop-blur-sm"
					>
						<div class="relative">
							{/* preload=none: nothing downloads until the visitor asks for the film */}
							<video
								src={videoSrc}
								poster={videoPoster}
								controls
								playsinline
								preload="none"
								class="aspect-video w-full bg-graphite"
							>
								<p class="p-6 text-paper">
									Your browser can't play this video —
									<a href={videoSrc} class="text-emerald-glow underline">download it instead</a>.
								</p>
							</video>
							<button
								type="button"
								data-video-close
								aria-label="Close video"
								class="absolute top-3 right-3 z-10 flex h-9 w-9 cursor-pointer items-center justify-center rounded-full bg-ink/70 text-paper transition-colors hover:bg-ink"
							>
								<svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
									<path d="M6 6l12 12M18 6L6 18"></path>
								</svg>
							</button>
						</div>
					</dialog>
				</>
			)
		}
	</div>
	<a href={href} class="absolute inset-0" tabindex="-1" aria-hidden="true"></a>
</article>

<script>
	for (const trigger of document.querySelectorAll<HTMLButtonElement>('[data-video-trigger]')) {
		const dialog = trigger.nextElementSibling as HTMLDialogElement | null;
		if (!dialog || !dialog.matches('[data-video-modal]')) continue;
		const video = dialog.querySelector('video');

		trigger.addEventListener('click', () => {
			dialog.showModal();
			video?.play().catch(() => {
				/* the visitor can press play on the native controls */
			});
		});
		// Native close (Esc, ✕, backdrop) — always stop playback
		dialog.addEventListener('close', () => video?.pause());
		dialog.querySelector('[data-video-close]')?.addEventListener('click', () => dialog.close());
		dialog.addEventListener('click', (e) => {
			if (e.target === dialog) dialog.close();
		});
	}
</script>
