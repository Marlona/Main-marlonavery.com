---
interface Props {
	title: string;
	abstract: string;
	tier: 'signature' | 'standard';
	duration: string;
	audience: string[];
	objectives?: string[];
	takeaways?: string[];
}

const { title, abstract, tier, duration, audience, objectives = [], takeaways = [] } = Astro.props;
const detailId = `talk-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<article class="reveal rounded-2xl bg-graphite p-8 text-paper">
	<div class="flex flex-wrap items-center gap-3">
		{
			tier === 'signature' && (
				<span class="rounded-full bg-emerald px-3 py-1 text-xs font-bold tracking-wide text-ink uppercase">Signature</span>
			)
		}
		<span class="text-sm text-mist">{duration}</span>
	</div>
	<h3 class="mt-4 font-display text-2xl font-semibold">{title}</h3>
	<p class="mt-3 leading-relaxed text-paper/75">{abstract}</p>
	<p class="mt-4 text-sm text-mist">
		<span class="font-semibold text-paper">Ideal for:</span> {audience.join(' · ')}
	</p>

	{
		(objectives.length > 0 || takeaways.length > 0) && (
			<details class="group mt-5">
				<summary
					class="cursor-pointer list-none text-sm font-semibold text-emerald-glow hover:underline [&::-webkit-details-marker]:hidden"
					aria-controls={detailId}
				>
					<span class="group-open:hidden">What your audience gets →</span>
					<span class="hidden group-open:inline">Show less ↑</span>
				</summary>
				<div id={detailId} class="mt-4 grid gap-6 md:grid-cols-2">
					{objectives.length > 0 && (
						<div>
							<h4 class="text-eyebrow text-mist">Learning objectives</h4>
							<ul class="mt-3 space-y-2 text-sm text-paper/80">
								{objectives.map((o) => (
									<li class="flex gap-2">
										<span class="text-emerald-glow" aria-hidden="true">
											◆
										</span>
										{o}
									</li>
								))}
							</ul>
						</div>
					)}
					{takeaways.length > 0 && (
						<div>
							<h4 class="text-eyebrow text-mist">Takeaways</h4>
							<ul class="mt-3 space-y-2 text-sm text-paper/80">
								{takeaways.map((t) => (
									<li class="flex gap-2">
										<span class="text-gold" aria-hidden="true">
											◆
										</span>
										{t}
									</li>
								))}
							</ul>
						</div>
					)}
				</div>
			</details>
		)
	}
</article>
