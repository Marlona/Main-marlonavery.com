---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollSequence from '../components/ScrollSequence.astro';
import Section from '../components/Section.astro';
import TrustedBy from '../components/TrustedBy.astro';
import Stats from '../components/Stats.astro';
import ProjectCard from '../components/ProjectCard.astro';
import EventCard from '../components/EventCard.astro';
import Gallery from '../components/Gallery.astro';
import { HERO_CLIPS } from '../data/heroClips';
import { SITE_CONFIG } from '../config';

import workshopFloor from '../assets/photos/workshop-floor-facilitation.jpg';
import whiteboard from '../assets/photos/live-whiteboard-session.jpg';
import stageLecture from '../assets/photos/stage-1.jpg';
import portrait from '../assets/photos/portrait-1.jpg';

const projects = (await getCollection('projects', ({ data }) => data.featured && !data.confidential))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

const talks = (await getCollection('speaking')).sort((a, b) => a.data.order - b.data.order);
const signatureTalks = talks.filter((t) => t.data.tier === 'signature').slice(0, 2);

const events = (await getCollection('events')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const upcomingEvents = events.filter((e) => e.data.status === 'upcoming').slice(0, 1);

/** Recently on stage — real keynotes and panels from the engagement archive, deduped by series */
const stageHighlights: typeof events = [];
const seenSeries = new Set<string>();
for (const e of events) {
	if (e.data.status !== 'past' || (e.data.type !== 'keynote' && e.data.type !== 'panel')) continue;
	const series = e.data.title.replace(/#?\s*\d+$/, '').trim().toLowerCase();
	if (seenSeries.has(series)) continue;
	seenSeries.add(series);
	stageHighlights.push(e);
	if (stageHighlights.length === 4) break;
}

const stageFmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric', timeZone: 'UTC' });

const roles = ['Applied AI Executive', 'Engineer', 'Founder', 'Builder', 'Educator', 'Speaker'];

const philosophyCards = [
	{
		index: '01',
		title: 'Build',
		text: 'Ship real systems where constraints are honest and outcomes are measurable. Real AI products, assistants, and workflows — because real stakes force clarity.',
		href: '/projects',
		linkLabel: 'See the work',
	},
	{
		index: '02',
		title: 'Learn',
		text: 'Building creates understanding. Every production system surfaces lessons you can’t read in a blog post — what broke, what surprised you, what actually matters.',
		href: '/about',
		linkLabel: 'The story',
	},
	{
		index: '03',
		title: 'Teach',
		text: 'Complex ideas become simple. Knowledge becomes accessible. 10,000+ professionals trained through sessions designed around the moment technology finally clicks.',
		href: '/workshops',
		linkLabel: 'Explore workshops',
	},
	{
		index: '04',
		title: 'Inspire',
		text: 'The goal isn’t to transfer knowledge — it’s to show people what’s possible so they go build their own thing. People leave believing: “I can build this too.”',
		href: '/workshops#enroll',
		linkLabel: 'Start your journey',
	},
];

const intentCards = [
	{
		title: 'Book a Keynote',
		text: 'Premium AI keynotes for conferences, summits, and executive events.',
		href: '/book?intent=keynote',
		cta: 'Book a keynote',
	},
	{
		title: 'Book a Workshop',
		text: 'Hands-on corporate AI training for your team — fundamentals to executive strategy.',
		href: '/book?intent=workshop',
		cta: 'Book a workshop',
	},
	{
		title: 'Learn AI',
		text: 'Start where you are. A guided path from curiosity to capability.',
		href: '/book?intent=learn',
		cta: 'Start learning',
	},
	{
		title: 'Build an AI Curriculum',
		text: 'Custom AI curricula for your organization, university, or program — designed and taught by a builder.',
		href: '/book?intent=curriculum',
		cta: 'Book a consult',
	},
];

const credibilityStats = [
	{ value: '100+', label: 'Workshops Taught' },
	{ value: '10,000+', label: 'Participants Trained' },
	{ value: '10+', label: 'Industries Served' },
	{ value: '10+', label: 'Years in Applied AI' },
];
---

<BaseLayout darkHero description={SITE_CONFIG.description}>
	<!-- HERO — Marlon walking a live workshop classroom -->
	{
		HERO_CLIPS.hero && (
			<ScrollSequence
				src={HERO_CLIPS.hero.src}
				srcMobile={HERO_CLIPS.hero.srcMobile}
				poster={HERO_CLIPS.hero.poster}
				scrollScreens={3}
				overlay="dark"
				priority
				label="Cinematic film of Marlon Avery walking through a workshop classroom while participants work"
			>
				<div class="flex h-full flex-col justify-end px-6 pb-24 md:px-12">
					<div class="mx-auto w-full max-w-7xl">
						<h1 class="text-display-lg animate-fade-up max-w-4xl text-paper">
							Building AI.<br />
							<span class="text-emerald-glow">Teaching the Future.</span>
						</h1>
						<p class="animate-fade-in mt-8 max-w-xl text-lg leading-relaxed text-paper/80" style="animation-delay: 0.4s">
							Marlon Avery helps leaders, teams, and organizations understand artificial intelligence by
							building real systems, teaching practical workflows, and creating moments where complex
							technology finally clicks.
						</p>
						<div class="animate-fade-in mt-10 flex flex-wrap gap-4" style="animation-delay: 0.7s">
							<a
								href="/speaking"
								class="rounded-full bg-emerald px-8 py-4 font-semibold text-ink transition-transform hover:scale-105"
							>
								Book Marlon to Speak
							</a>
							<a
								href="/workshops"
								class="rounded-full border border-paper/40 px-8 py-4 font-semibold text-paper transition-colors hover:border-emerald-glow hover:text-emerald-glow"
							>
								Explore Workshops
							</a>
						</div>
						<p class="mt-16 hidden items-center gap-3 text-xs tracking-[0.2em] text-paper/50 uppercase md:flex">
							<span class="inline-block h-8 w-px animate-pulse bg-emerald-glow" aria-hidden="true"></span>
							Scroll — the film follows you
						</p>
					</div>
				</div>
			</ScrollSequence>
		)
	}

	<!-- TRUSTED BY — scrolling marquee -->
	<TrustedBy />

	<!-- IDENTITY — editorial portrait split -->
	<section id="who" class="bg-paper px-6 py-24 text-ink md:py-32">
		<div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-12 lg:gap-16">
			<!-- Portrait -->
			<figure class="reveal relative lg:col-span-5">
				<div class="absolute -inset-3 -z-10 rounded-3xl bg-emerald/10" aria-hidden="true"></div>
				<Image
					src={portrait}
					alt="Marlon Avery speaking on a fireside-chat stage"
					widths={[400, 720, 1000]}
					sizes="(max-width: 1024px) 100vw, 40vw"
					class="aspect-[4/5] w-full rounded-3xl object-cover object-top"
				/>
				<figcaption class="absolute bottom-4 left-4 rounded-full bg-ink/85 px-4 py-2 text-xs font-semibold tracking-wide text-paper uppercase backdrop-blur-sm">
					VP, Applied AI Lead · Founder · Educator
				</figcaption>
			</figure>

			<!-- Statement -->
			<div class="lg:col-span-7">
				<p class="text-eyebrow reveal text-emerald-deep">Who is Marlon Avery</p>
				<h2 class="text-display-md reveal mt-5 max-w-xl">
					The engineer behind <span class="text-emerald-deep">engineering AI.</span>
				</h2>
				<p class="reveal mt-6 max-w-xl text-lg leading-relaxed text-slate">
					Not an AI commentator. Not a futurist with a slide deck. Marlon designs, builds, deploys, and
					scales AI systems — then teaches everyone else how to do it too.
				</p>

				<ul class="reveal mt-10 grid max-w-lg grid-cols-2 gap-x-8 gap-y-4" aria-label="Marlon's roles">
					{
						roles.map((role) => (
							<li class="flex items-center gap-3 border-t border-ink/10 pt-4">
								<span class="h-1.5 w-1.5 shrink-0 rounded-full bg-emerald" aria-hidden="true" />
								<span class="font-display text-lg font-semibold tracking-tight">{role}</span>
							</li>
						))
					}
				</ul>

				<a
					href="/about"
					class="reveal mt-10 inline-block rounded-full bg-ink px-7 py-3.5 text-sm font-semibold text-paper transition-colors hover:bg-emerald-deep"
				>
					Read his story →
				</a>
			</div>
		</div>
	</section>

	<!-- PHILOSOPHY — four cards -->
	<Section
		tone="dark"
		eyebrow="The philosophy"
		title="Build. Learn. Teach. Inspire."
		intro="One flywheel drives everything: build real systems, extract the lessons, teach them in ways that stick — and inspire the next builder."
	>
		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
			{
				philosophyCards.map((card) => (
					<div class="reveal flex flex-col rounded-2xl bg-graphite p-8">
						<p class="text-eyebrow text-emerald-glow">{card.index}</p>
						<h3 class="mt-3 font-display text-3xl font-semibold">{card.title}</h3>
						<p class="mt-4 leading-relaxed text-paper/75">{card.text}</p>
						<a href={card.href} class="mt-auto pt-6 text-sm font-semibold text-emerald-glow hover:underline">
							{card.linkLabel} →
						</a>
					</div>
				))
			}
		</div>
	</Section>

	<!-- PROOF OF IMPACT — anchored by The Builder film -->
	{
		HERO_CLIPS.builder && (
			<ScrollSequence
				src={HERO_CLIPS.builder.src}
				srcMobile={HERO_CLIPS.builder.srcMobile}
				poster={HERO_CLIPS.builder.poster}
				scrollScreens={2}
				label="Cinematic film of Marlon Avery working at a dark desk surrounded by screens showing his projects"
				id="builder-film"
			>
				<div class="flex h-full items-end px-6 pb-20 md:px-12">
					<div class="mx-auto w-full max-w-7xl">
						<p class="text-eyebrow text-emerald-glow">Proof of impact</p>
						<h2 class="text-display-lg mt-4 max-w-3xl text-paper">Selected work.</h2>
					</div>
				</div>
			</ScrollSequence>
		)
	}
	<Section tone="dark">
		<div class="grid gap-6 md:grid-cols-2">
			{
				projects.map((project) => (
					<ProjectCard
						href={`/projects/${project.id}`}
						title={project.data.title.split('—')[0].trim()}
						description={project.data.description}
						impact={project.data.impactSummary}
						tech={project.data.primaryTech}
						date={project.data.publishDate}
						videoUrl={project.data.videoUrl && `/projects/${project.id}#film`}
					/>
				))
			}
		</div>
		<a href="/projects" class="reveal mt-10 inline-block font-semibold text-emerald-glow hover:underline">
			All projects →
		</a>
	</Section>

	<!-- SPEAKING + ON STAGE -->
	<Section
		eyebrow="Speaking"
		title="Keynotes that move rooms."
		intro="High-signal talks grounded in what actually ships in enterprise AI — tailored to your audience, industry, and moment."
	>
		<div class="grid gap-6 md:grid-cols-2">
			{
				signatureTalks.map((talk) => (
					<a
						href="/speaking"
						class="reveal group block rounded-2xl border border-ink/10 bg-cream p-8 transition-all hover:-translate-y-1 hover:border-emerald/60 hover:shadow-xl"
					>
						<div class="flex flex-wrap items-center gap-3">
							<span class="rounded-full bg-emerald px-3 py-1 text-xs font-bold tracking-wide text-ink uppercase">Signature</span>
							<span class="text-sm text-slate">{talk.data.duration}</span>
						</div>
						<h3 class="mt-4 font-display text-2xl font-semibold group-hover:text-emerald-deep">{talk.data.title}</h3>
						<p class="mt-3 leading-relaxed text-slate">{talk.data.abstract}</p>
						<span class="mt-6 inline-block text-sm font-semibold text-emerald-deep group-hover:underline">All keynotes →</span>
					</a>
				))
			}
		</div>

		<div class="mt-16 grid gap-12 lg:grid-cols-2">
			<div>
				<h3 class="text-eyebrow reveal text-emerald-deep">Recently on stage</h3>
				<ul class="mt-5 divide-y divide-ink/8">
					{
						stageHighlights.map((e) => (
							<li class="reveal flex flex-wrap items-baseline gap-x-4 gap-y-1 py-4">
								<time
									datetime={e.data.date.toISOString().slice(0, 10)}
									class="w-24 shrink-0 text-sm font-semibold text-slate"
								>
									{stageFmt.format(e.data.date)}
								</time>
								<div class="min-w-0 flex-1">
									<p class="font-semibold">{e.data.title}</p>
									<p class="text-sm text-slate">
										{[e.data.description !== e.data.title ? e.data.description : null, e.data.city]
											.filter(Boolean)
											.join(' · ')}
									</p>
								</div>
								<span class="text-xs font-semibold tracking-wide text-emerald-deep uppercase">{e.data.type}</span>
							</li>
						))
					}
				</ul>
			</div>
			<div>
				<h3 class="text-eyebrow reveal text-emerald-deep">Up next</h3>
				<div class="mt-5 space-y-6">
					{
						upcomingEvents.map((e) => (
							<EventCard
								title={e.data.title}
								date={e.data.date}
								endDate={e.data.endDate}
								type={e.data.type}
								city={e.data.city}
								venue={e.data.venue}
								description={e.data.description}
								upcoming
							/>
						))
					}
					<a href="/events" class="reveal inline-block font-semibold text-emerald-deep hover:underline">
						All events →
					</a>
				</div>
			</div>
		</div>
	</Section>

	<!-- TRACK RECORD -->
	<Section
		tone="cream"
		eyebrow="Track record"
		title="Enterprise organizations. Real classrooms. Real stages."
		intro="From Microsoft-contracted Azure OpenAI bootcamps to the Google AI Library Project’s five-city tour — Marlon teaches where it counts."
	>
		<Stats stats={credibilityStats} />
		<div class="mt-16">
			<Gallery
				images={[
					{ src: stageLecture, alt: 'Marlon Avery teaching an Emerging AI Career Path session from a lectern', span: true, caption: 'Teaching an AI career-path session' },
					{ src: workshopFloor, alt: 'Marlon working one-on-one with a workshop participant at a laptop' },
					{ src: whiteboard, alt: 'Marlon leading a live whiteboard strategy session' },
				]}
			/>
		</div>
	</Section>

	<!-- WHAT BRINGS YOU HERE -->
	<Section eyebrow="Choose your journey" title="What brings you here?">
		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
			{
				intentCards.map((card) => (
					<a
						href={card.href}
						class="reveal group flex flex-col rounded-2xl border border-ink/10 bg-cream p-8 transition-all duration-300 hover:-translate-y-1 hover:border-emerald/60 hover:shadow-xl"
					>
						<h3 class="font-display text-xl font-semibold group-hover:text-emerald-deep">{card.title}</h3>
						<p class="mt-3 text-sm leading-relaxed text-slate">{card.text}</p>
						<span class="mt-auto pt-8">
							<span class="inline-block rounded-full bg-ink px-5 py-2.5 text-sm font-bold text-paper transition-colors group-hover:bg-emerald-deep">
								{card.cta} →
							</span>
						</span>
					</a>
				))
			}
		</div>
	</Section>

	<!-- FINAL CTA -->
	<section class="theme-fixed bg-ink px-6 py-28 text-paper md:py-40">
		<div class="mx-auto max-w-7xl">
			<h2 class="text-display-lg reveal max-w-4xl">Let’s build what’s next.</h2>
			<div class="reveal mt-10 flex flex-wrap gap-4">
				<a href="/book?intent=keynote" class="rounded-full bg-emerald px-8 py-4 font-semibold text-ink transition-transform hover:scale-105">
					Book Marlon to Speak
				</a>
				<a href="/projects" class="rounded-full border border-paper/40 px-8 py-4 font-semibold text-paper transition-colors hover:border-emerald-glow hover:text-emerald-glow">
					Explore His Work
				</a>
			</div>
		</div>
	</section>
</BaseLayout>
