---
import MaverickLayout from '../../layouts/MaverickLayout.astro';
import ElevateWizard from '../../components/maverick/ElevateWizard.astro';
import { ASSESSMENT_DIMENSIONS, ASSESSMENT_FREE_TEXT } from '../../data/elevateAssessment';

/**
 * Growth = Elevate — the coaching engine (Intentional Development Model).
 * Morning-first ritual, destination, framework-validated affirmations,
 * observation-framed proposals from the nightly adjustment loop, the intake
 * assessment with quarterly A→B deltas, and the journey lineage. Maverick's
 * memory management lives at the bottom. Conversational work (declaring the
 * destination, seed-then-shape, coaching) happens in chat — this page is the
 * instrument panel.
 */
---

<MaverickLayout title="Maverick — Elevate" active="growth">
	<h1 class="text-display-sm mt-8">Elevate.</h1>
	<p class="mt-2 max-w-2xl text-sm text-paper/60">
		From where you are to where you said you want to go. Observe, don't judge.
	</p>

	<!-- Morning ritual -->
	<section class="mt-6 rounded-3xl bg-emerald-deep/25 p-7" aria-labelledby="ritual-h" data-ritual>
		<div class="flex flex-wrap items-center justify-between gap-4">
			<h2 id="ritual-h" class="text-eyebrow text-emerald-glow">Morning ritual</h2>
			<button
				type="button"
				data-ritual-read
				class="cursor-pointer rounded-full bg-emerald px-6 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105"
			>
				Mark as read
			</button>
		</div>
		<div class="mt-4 space-y-4" data-ritual-list aria-live="polite">
			<p class="text-paper/60">Loading…</p>
		</div>
		<p class="mt-5 border-t border-paper/15 pt-4 text-sm text-paper/70" data-ritual-observe></p>
	</section>

	<!-- Destination -->
	<section class="mt-6 rounded-2xl bg-graphite p-6" aria-labelledby="dest-h">
		<div class="flex flex-wrap items-center justify-between gap-3">
			<h2 id="dest-h" class="text-eyebrow text-mist">Destination — Place B</h2>
			<div class="flex gap-2">
				<a href="/maverick?ask=Let's revisit my destination — where I'm headed and what it's worth to me." class="rounded-full border border-paper/25 px-4 py-1.5 text-xs font-bold hover:border-emerald-glow hover:text-emerald-glow" data-dest-revise>
					Revise in chat
				</a>
				<button type="button" data-dest-restart hidden class="cursor-pointer rounded-full border border-paper/25 px-4 py-1.5 text-xs font-bold hover:border-emerald-glow hover:text-emerald-glow">
					Start over
				</button>
			</div>
		</div>
		<div class="mt-3" data-destination>
			<p class="text-paper/60">Loading…</p>
		</div>
	</section>

	<!-- Elevate noticed (open proposals) -->
	<section class="mt-6" aria-labelledby="noticed-h" data-noticed-section hidden>
		<h2 id="noticed-h" class="text-eyebrow text-gold">Elevate noticed</h2>
		<div class="mt-3 space-y-3" data-noticed></div>
	</section>

	<!-- Active affirmations -->
	<section class="mt-8" aria-labelledby="active-h">
		<div class="flex flex-wrap items-baseline justify-between gap-3">
			<h2 id="active-h" class="text-eyebrow text-mist">Active set</h2>
			<p class="text-xs text-paper/50" data-resonance-strip></p>
		</div>
		<div class="mt-3 space-y-3" data-active-list>
			<p class="text-paper/60">Loading…</p>
		</div>
		<a href="/maverick?ask=Let's work on my affirmations. I want to seed a couple in my own words first." class="mt-4 inline-block text-sm font-semibold text-emerald-glow hover:underline">
			Shape the set in chat →
		</a>
	</section>

	<!-- Evening check-in -->
	<section class="mt-8 rounded-2xl bg-graphite p-6" aria-labelledby="evening-h" data-evening hidden>
		<h2 id="evening-h" class="text-eyebrow text-mist">Evening check-in — 30 seconds</h2>
		<form data-evening-form class="mt-4 space-y-4">
			<div>
				<p class="text-sm font-semibold">Did today's set feel true?</p>
				<div class="mt-2 flex gap-2" role="radiogroup" aria-label="Resonance score 1 to 5">
					{
						[1, 2, 3, 4, 5].map((n) => (
							<label class="cursor-pointer">
								<input type="radio" name="resonance" value={n} class="peer sr-only" required />
								<span class="block rounded-full border border-paper/25 px-4 py-2 text-sm font-bold peer-checked:border-emerald peer-checked:bg-emerald peer-checked:text-ink">
									{n}
								</span>
							</label>
						))
					}
				</div>
			</div>
			<label class="flex items-center gap-2.5 text-sm">
				<input type="checkbox" name="connection" class="h-4 w-4 accent-emerald" />
				Something happened today that connects
			</label>
			<label class="block">
				<span class="text-sm font-semibold">One line, if it wants out</span>
				<div class="relative mt-1.5">
					<input type="text" name="notes" class="w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 pr-12 text-base text-paper focus:border-emerald sm:text-sm" />
					<button type="button" data-evening-mic aria-label="Dictate" aria-pressed="false" class="wiz-mic absolute top-1/2 right-2 -translate-y-1/2 !h-7 !w-7">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
							<rect x="9" y="2" width="6" height="12" rx="3"></rect>
							<path d="M5 10v1a7 7 0 0 0 14 0v-1"></path>
							<line x1="12" y1="18" x2="12" y2="22"></line>
						</svg>
					</button>
				</div>
			</label>
			<div class="flex items-center gap-3">
				<button type="submit" class="cursor-pointer rounded-full bg-emerald px-6 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105">Save</button>
				<p class="text-sm text-emerald-glow" data-evening-status role="status"></p>
			</div>
		</form>
	</section>

	<!-- Assessment -->
	<section class="mt-10 border-t border-paper/15 pt-8" aria-labelledby="assess-h">
		<div class="flex flex-wrap items-baseline justify-between gap-3">
			<h2 id="assess-h" class="text-display-sm">Where you are. Where you're going.</h2>
			<p class="text-sm text-paper/55" data-assess-meta></p>
		</div>
		<div class="mt-4" data-delta hidden>
			<h3 class="text-eyebrow text-emerald-glow">Your movement since last time</h3>
			<div class="mt-3 space-y-2" data-delta-bars></div>
		</div>
		<details class="mt-4 rounded-2xl bg-graphite p-6" data-assess-details>
			<summary class="cursor-pointer font-display text-lg font-semibold [&::-webkit-details-marker]:hidden" data-assess-summary>
				Take the assessment (~5 minutes)
			</summary>
			<form data-assess-form class="mt-6 space-y-6">
				<p class="text-sm text-paper/60">
					For each area: where you are today (1–10), where you want to be (1–10), and how comfortable
					this area feels to talk about (1–5). Honest beats impressive.
				</p>
				{
					ASSESSMENT_DIMENSIONS.map((dim) => (
						<fieldset class="rounded-xl bg-ink/50 p-4">
							<legend class="px-1 text-sm font-semibold">{dim.label}</legend>
							<div class="mt-2 grid gap-4 sm:grid-cols-3">
								<label class="block text-xs">
									<span class="text-paper/60">
										Today (A): <output data-out={`${dim.id}-a`}>5</output>
									</span>
									<input type="range" min="1" max="10" value="5" name={`${dim.id}:a`} data-range={`${dim.id}-a`} class="mt-1 w-full accent-emerald" />
								</label>
								<label class="block text-xs">
									<span class="text-paper/60">
										Want (B): <output data-out={`${dim.id}-b`}>8</output>
									</span>
									<input type="range" min="1" max="10" value="8" name={`${dim.id}:b`} data-range={`${dim.id}-b`} class="mt-1 w-full accent-emerald" />
								</label>
								<label class="block text-xs">
									<span class="text-paper/60">
										Comfort discussing: <output data-out={`${dim.id}-c`}>3</output>
									</span>
									<input type="range" min="1" max="5" value="3" name={`${dim.id}:c`} data-range={`${dim.id}-c`} class="mt-1 w-full accent-gold" />
								</label>
							</div>
						</fieldset>
					))
				}
				{
					ASSESSMENT_FREE_TEXT.map((q) => (
						<label class="block">
							<span class="text-sm font-semibold">{q.label}</span>
							<textarea name={q.id} rows="2" class="mt-1.5 w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 text-base text-paper focus:border-emerald sm:text-sm" />
						</label>
					))
				}
				<div class="flex items-center gap-3">
					<button type="submit" class="cursor-pointer rounded-full bg-emerald px-7 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105">
						Save assessment
					</button>
					<p class="text-sm text-emerald-glow" data-assess-status role="status"></p>
				</div>
			</form>
		</details>
	</section>

	<!-- Journey -->
	<section class="mt-10" aria-labelledby="journey-h">
		<h2 id="journey-h" class="text-eyebrow text-mist">The journey</h2>
		<ol class="mt-3 space-y-2" data-journey>
			<li class="text-paper/55">Loading…</li>
		</ol>
	</section>

	<!-- Wins & reflections (folded) -->
	<details class="mt-8 rounded-2xl bg-graphite p-6">
		<summary class="text-eyebrow cursor-pointer list-none text-mist [&::-webkit-details-marker]:hidden">Wins & reflections</summary>
		<div class="mt-4 grid gap-6 lg:grid-cols-2">
			<div>
				<h3 class="text-xs font-bold tracking-wide text-paper/55 uppercase">Wins — last 14 days</h3>
				<ul class="mt-3 space-y-2.5 text-sm" data-wins>
					<li class="text-paper/55">Loading…</li>
				</ul>
			</div>
			<div>
				<h3 class="text-xs font-bold tracking-wide text-paper/55 uppercase">Reflections</h3>
				<ul class="mt-3 space-y-4 text-sm" data-reflections>
					<li class="text-paper/55">Loading…</li>
				</ul>
			</div>
		</div>
	</details>

	<!-- Maverick's memory -->
	<section class="mt-12 border-t border-paper/15 pt-10" aria-labelledby="mem-h">
		<div class="flex flex-wrap items-baseline justify-between gap-3">
			<h2 id="mem-h" class="text-display-sm">What Maverick remembers.</h2>
			<p class="text-sm text-paper/55" data-mem-count>—</p>
		</div>
		<p class="mt-2 max-w-2xl text-sm text-paper/60">
			Everything Maverick has learned about you — from chats and nightly distillation. Search it, fix it, or forget it.
		</p>

		<div class="mt-6 flex flex-wrap gap-3">
			<label class="min-w-0 flex-1">
				<span class="sr-only">Search memories</span>
				<input
					type="search"
					data-mem-search
					placeholder="Search by meaning — e.g. “podcast co-hosts” or “what matters to me”…"
					class="w-full rounded-xl border border-paper/20 bg-graphite px-4 py-2.5 text-base text-paper focus:border-emerald sm:text-sm"
				/>
			</label>
			<button type="button" data-mem-add class="cursor-pointer rounded-xl bg-emerald px-5 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105">
				+ Add memory
			</button>
		</div>

		<p class="mt-4 text-sm text-terracotta" data-mem-error role="alert" hidden></p>
		<ul class="mt-5 space-y-3" data-mem-list>
			<li class="text-paper/55">Loading…</li>
		</ul>
	</section>

	<!-- Add / edit memory dialog -->
	<dialog data-mem-dialog class="theme-fixed m-auto w-[min(94vw,560px)] rounded-2xl border border-paper/20 bg-graphite p-0 text-paper backdrop:bg-ink/70">
		<form method="dialog" data-mem-form class="p-7">
			<h3 class="font-display text-2xl font-semibold" data-mem-dialog-title>Add memory</h3>
			<div class="mt-5 space-y-4">
				<div>
					<label for="mem-content" class="block text-sm font-semibold">Memory</label>
					<textarea id="mem-content" name="content" rows="4" required class="mt-1.5 w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 text-base text-paper focus:border-emerald sm:text-sm"></textarea>
				</div>
				<div>
					<label for="mem-kind" class="block text-sm font-semibold">Kind</label>
					<select id="mem-kind" name="kind" class="mt-1.5 w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 text-base text-paper focus:border-emerald sm:text-sm">
						<option value="fact">Fact</option>
						<option value="preference">Preference</option>
						<option value="decision">Decision</option>
						<option value="person">Person</option>
						<option value="project_context">Project context</option>
						<option value="conversation_summary">Conversation summary</option>
					</select>
				</div>
			</div>
			<div class="mt-6 flex gap-3">
				<button type="submit" value="save" class="cursor-pointer rounded-full bg-emerald px-7 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105">Save</button>
				<button type="submit" value="cancel" formnovalidate class="cursor-pointer rounded-full border border-paper/30 px-6 py-2.5 text-sm font-semibold hover:border-emerald-glow">Cancel</button>
			</div>
		</form>
	</dialog>

	<ElevateWizard />
</MaverickLayout>

<script>
	import { initMaverick, esc, fmtDate, todayISO, invokeFn } from '../../lib/maverick/client';
	import { initElevateWizard } from '../../lib/maverick/elevateWizard';
	import { attachDictation } from '../../lib/maverick/dictation';
	import { OBSERVATION_PROMPTS, DISCOMFORT_THRESHOLD, ASSESSMENT_DIMENSIONS, ASSESSMENT_FREE_TEXT } from '../../data/elevateAssessment';
	import type { Tables } from '../../lib/maverick/db-types';

	type Affirmation = Tables<'affirmations'>;
	type AgentEvent = Tables<'agent_events'>;

	const db = await initMaverick();
	const today = todayISO();

	const fnCall = (fn: string, body: Record<string, unknown>) => invokeFn(db, fn, body);

	// ------------------------------------------------------ Morning ritual --
	const ritualList = document.querySelector<HTMLElement>('[data-ritual-list]')!;
	const ritualBtn = document.querySelector<HTMLButtonElement>('[data-ritual-read]')!;
	const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000);
	document.querySelector('[data-ritual-observe]')!.textContent = `Today's observation: ${OBSERVATION_PROMPTS[dayOfYear % OBSERVATION_PROMPTS.length]}`;

	let actives: Affirmation[] = [];

	const loadRitual = async () => {
		const [activesRes, readRes] = await Promise.all([
			db.from('affirmations').select('*').eq('status', 'active').order('created_at', { ascending: true }),
			db.from('affirmation_checkins').select('id').eq('type', 'morning').gte('created_at', `${today}T00:00:00`).limit(1),
		]);
		actives = activesRes.data ?? [];
		const readToday = (readRes.data ?? []).length > 0;
		ritualList.innerHTML = actives.length
			? actives.map((a) => `<blockquote class="font-display text-xl leading-snug font-medium md:text-2xl">“${esc(a.text)}”</blockquote>`).join('')
			: '<p class="text-paper/60">No active set yet — hit “Let\'s start here” under Destination and Elevate builds it with you.</p>';
		ritualBtn.disabled = readToday || !actives.length;
		ritualBtn.textContent = readToday ? 'Read this morning ✓' : 'Mark as read';
	};

	ritualBtn.addEventListener('click', async () => {
		await db.from('affirmation_checkins').insert({ type: 'morning', read: true });
		loadRitual();
	});

	// -------------------------------------------------------- Destination --
	const loadDestination = async () => {
		const { data: goal } = await db.from('goals').select('*').eq('status', 'active').order('created_at', { ascending: false }).limit(1).maybeSingle();
		const el = document.querySelector<HTMLElement>('[data-destination]')!;
		const reviseBtn = document.querySelector<HTMLElement>('[data-dest-revise]')!;
		const restartBtn = document.querySelector<HTMLElement>('[data-dest-restart]')!;
		if (!goal) {
			el.innerHTML = `
				<p class="max-w-xl text-paper/70">From where you are to where you said you want to go — Elevate walks it with you, one question at a time. About ten minutes. Talk or type.</p>
				<button type="button" data-wiz-open class="mt-4 cursor-pointer rounded-full bg-emerald px-7 py-3 text-sm font-bold text-ink transition-transform hover:scale-105">Let's start here →</button>`;
			el.querySelector('[data-wiz-open]')!.addEventListener('click', () => wizard.open());
			reviseBtn.hidden = true;
			restartBtn.hidden = true;
			return;
		}
		reviseBtn.hidden = false;
		restartBtn.hidden = false;
		const commitment = { life_changing: 'Life-changing', sticking_point: 'Sticking point', exploring: 'Exploring' }[goal.commitment_level] ?? goal.commitment_level;
		el.innerHTML = `
			<p class="font-display text-xl leading-snug font-medium">“${esc(goal.destination_text)}”</p>
			<p class="mt-3 flex flex-wrap items-center gap-2 text-xs">
				<span class="rounded-full bg-emerald-deep/40 px-2.5 py-0.5 font-bold text-emerald-glow uppercase">${esc(commitment)}</span>
				${goal.worth_statement ? `<span class="text-paper/60">Worth: ${esc(goal.worth_statement)}</span>` : ''}
			</p>
			${goal.place_a_summary ? `<p class="mt-2 text-sm text-paper/60">Place A: ${esc(goal.place_a_summary)}</p>` : ''}`;
	};

	// ------------------------------------------------------ Elevate noticed --
	const EVENT_LABELS: Record<string, string> = {
		resonance_decay: 'Resonance is fading',
		graduation: 'This one may be yours now',
		outgrown: 'You may have outgrown this',
		stall: 'A lesson keeps returning',
		new_influence: 'A new influence keeps appearing',
		goal_drift: 'Your direction language is shifting',
		disengagement: 'Welcome back',
		cadence_due: 'A rhythm check is due',
	};

	const loadNoticed = async () => {
		const { data } = await db.from('agent_events').select('*').eq('status', 'open').order('created_at', { ascending: true });
		const events = (data ?? []) as AgentEvent[];
		const section = document.querySelector<HTMLElement>('[data-noticed-section]')!;
		const wrap = document.querySelector<HTMLElement>('[data-noticed]')!;
		section.hidden = !events.length;
		wrap.innerHTML = events
			.map((e) => {
				const p = (e.payload ?? {}) as Record<string, unknown>;
				return `
			<article class="rounded-2xl border border-gold/40 bg-graphite p-5">
				<p class="text-xs font-bold tracking-wide text-gold uppercase">${esc(EVENT_LABELS[e.event_type] ?? e.event_type)}</p>
				${p.observation ? `<p class="mt-2 text-sm text-paper/80">${esc(String(p.observation))}</p>` : ''}
				${p.current_text ? `<p class="mt-2 text-xs text-paper/50">Current: “${esc(String(p.current_text))}”</p>` : ''}
				${p.proposed_text ? `<p class="mt-1.5 text-sm font-semibold text-emerald-glow">Proposed: “${esc(String(p.proposed_text))}”</p>` : ''}
				<div class="mt-4 flex gap-2.5">
					<button type="button" data-ev="${esc(e.id)}:accepted" class="cursor-pointer rounded-full bg-emerald px-5 py-2 text-xs font-bold text-ink transition-transform hover:scale-105">Accept</button>
					<button type="button" data-ev="${esc(e.id)}:dismissed" class="cursor-pointer rounded-full border border-paper/30 px-5 py-2 text-xs font-semibold hover:border-terracotta hover:text-terracotta">Dismiss</button>
				</div>
			</article>`;
			})
			.join('');
		wrap.querySelectorAll<HTMLButtonElement>('[data-ev]').forEach((btn) =>
			btn.addEventListener('click', async () => {
				const [id, decision] = btn.dataset.ev!.split(':');
				btn.disabled = true;
				try {
					await fnCall('maverick-elevate', { action: 'resolve_event', event_id: id, decision });
					loadNoticed();
					loadRitual();
					loadJourney();
				} catch (err) {
					alert(err instanceof Error ? err.message : 'Could not resolve.');
					btn.disabled = false;
				}
			}),
		);
	};

	// --------------------------------------------------- Active set + bars --
	const loadActiveSet = async () => {
		const { data: evenings } = await db
			.from('affirmation_checkins')
			.select('resonance_score,created_at')
			.eq('type', 'evening')
			.not('resonance_score', 'is', null)
			.order('created_at', { ascending: false })
			.limit(7);
		const scores = (evenings ?? []).reverse().map((c) => c.resonance_score as number);
		document.querySelector('[data-resonance-strip]')!.textContent = scores.length
			? `Resonance, last ${scores.length}: ${scores.map((n) => '▁▂▃▄▅'[n - 1]).join(' ')} (${scores.join(' · ')})`
			: 'No resonance scores yet — the evening check-in feeds this.';

		const TARGET_LABELS: Record<string, string> = { goal: 'Destination', discomfort_area: 'Discomfort area', self_talk_pattern: 'Self-talk', lesson: 'Lesson' };
		const wrap = document.querySelector<HTMLElement>('[data-active-list]')!;
		wrap.innerHTML = actives.length
			? actives
					.map(
						(a) => `
			<article class="rounded-2xl bg-graphite p-5">
				<p class="leading-snug">“${esc(a.text)}”</p>
				<div class="mt-3 flex flex-wrap items-center gap-2 text-[11px]">
					<span class="rounded-full bg-emerald-deep/40 px-2 py-0.5 font-bold text-emerald-glow uppercase">${esc(TARGET_LABELS[a.target ?? ''] ?? 'Destination')}</span>
					<span class="text-paper/50">v${a.version}</span>
					${a.user_seed_text ? '<span class="rounded-full border border-paper/25 px-2 py-0.5 text-paper/60">from your seed</span>' : ''}
					${a.target_ref ? `<span class="text-paper/45">${esc(a.target_ref)}</span>` : ''}
					<button type="button" data-graduate="${esc(a.id)}" class="ml-auto cursor-pointer rounded-full border border-paper/25 px-3 py-1 text-[11px] font-bold hover:border-emerald-glow hover:text-emerald-glow">This feels true now</button>
				</div>
			</article>`,
					)
					.join('')
			: '<p class="text-paper/60">The set builds from your destination — start in chat.</p>';

		wrap.querySelectorAll<HTMLButtonElement>('[data-graduate]').forEach((btn) =>
			btn.addEventListener('click', async () => {
				if (!confirm('Graduate this affirmation? It becomes internalized and Elevate writes the next level.')) return;
				btn.disabled = true;
				btn.textContent = 'Graduating…';
				try {
					const a = actives.find((x) => x.id === btn.dataset.graduate)!;
					const { data: event, error } = await db
						.from('agent_events')
						.insert({ event_type: 'graduation', payload: { affirmation_id: a.id, current_text: a.text, observation: 'Marlon says it reads as plain fact now.' } })
						.select('id')
						.single();
					if (error) throw new Error(error.message);
					await fnCall('maverick-elevate', { action: 'resolve_event', event_id: event.id, decision: 'accepted' });
					await loadRitual();
					await loadActiveSet();
					loadJourney();
				} catch (err) {
					alert(err instanceof Error ? err.message : 'Could not graduate.');
					btn.disabled = false;
					btn.textContent = 'This feels true now';
				}
			}),
		);
	};

	// ------------------------------------------------------ Evening check-in --
	const eveningSection = document.querySelector<HTMLElement>('[data-evening]')!;
	const eveningForm = document.querySelector<HTMLFormElement>('[data-evening-form]')!;
	const loadEvening = async () => {
		const hourET = Number(new Intl.DateTimeFormat('en-US', { hour: 'numeric', hour12: false }).format(new Date()));
		const { data } = await db.from('affirmation_checkins').select('id').eq('type', 'evening').gte('created_at', `${today}T00:00:00`).limit(1);
		eveningSection.hidden = !(hourET >= 18 && !(data ?? []).length && actives.length > 0);
	};
	eveningForm.addEventListener('submit', async (e) => {
		e.preventDefault();
		const form = new FormData(eveningForm);
		const { error } = await db.from('affirmation_checkins').insert({
			type: 'evening',
			read: true,
			resonance_score: Number(form.get('resonance')),
			behavior_connection: form.get('connection') === 'on',
			notes_text: String(form.get('notes') ?? '').trim() || null,
		});
		const status = document.querySelector<HTMLElement>('[data-evening-status]')!;
		status.textContent = error ? `Save failed: ${error.message}` : 'Saved ✓';
		if (!error) setTimeout(() => loadEvening(), 900);
	});
	attachDictation(
		document.querySelector<HTMLButtonElement>('[data-evening-mic]')!,
		eveningForm.querySelector<HTMLInputElement>('[name="notes"]')!,
	);

	// ---------------------------------------------------------- Assessment --
	document.querySelectorAll<HTMLInputElement>('[data-range]').forEach((range) => {
		range.addEventListener('input', () => {
			document.querySelector<HTMLElement>(`[data-out="${range.dataset.range}"]`)!.textContent = range.value;
		});
	});

	const assessForm = document.querySelector<HTMLFormElement>('[data-assess-form]')!;
	const loadAssessments = async () => {
		const { data } = await db.from('assessments').select('scored_dimensions,taken_at').order('taken_at', { ascending: false }).limit(2);
		const rows = data ?? [];
		document.querySelector('[data-assess-meta]')!.textContent = rows.length
			? `Last taken ${fmtDate(rows[0].taken_at)} · retake quarterly`
			: 'Not taken yet';
		document.querySelector('[data-assess-summary]')!.textContent = rows.length ? 'Retake the assessment (~5 minutes)' : 'Take the assessment (~5 minutes)';

		const deltaWrap = document.querySelector<HTMLElement>('[data-delta]')!;
		if (rows.length >= 2) {
			const latest = rows[0].scored_dimensions as Record<string, { a: number; b: number }>;
			const prior = rows[1].scored_dimensions as Record<string, { a: number; b: number }>;
			const bars = ASSESSMENT_DIMENSIONS.filter((d) => latest[d.id] && prior[d.id])
				.map((d) => {
					const move = latest[d.id].a - prior[d.id].a;
					const sign = move > 0 ? `+${move}` : `${move}`;
					const color = move > 0 ? 'text-emerald-glow' : move < 0 ? 'text-terracotta' : 'text-paper/50';
					return `
				<div class="flex items-center gap-3 text-sm">
					<span class="w-56 shrink-0 truncate text-paper/70">${esc(d.label)}</span>
					<span class="flex-1 rounded-full bg-ink/60"><span class="block h-2 rounded-full bg-emerald" style="width:${latest[d.id].a * 10}%"></span></span>
					<span class="w-14 text-right font-bold ${color}">${sign}</span>
				</div>`;
				})
				.join('');
			document.querySelector('[data-delta-bars]')!.innerHTML = bars;
			deltaWrap.hidden = !bars;
		} else {
			deltaWrap.hidden = true;
		}
	};

	assessForm.addEventListener('submit', async (e) => {
		e.preventDefault();
		const form = new FormData(assessForm);
		const scored: Record<string, { a: number; b: number; comfort: number }> = {};
		const flags: string[] = [];
		for (const dim of ASSESSMENT_DIMENSIONS) {
			const entry = { a: Number(form.get(`${dim.id}:a`)), b: Number(form.get(`${dim.id}:b`)), comfort: Number(form.get(`${dim.id}:c`)) };
			scored[dim.id] = entry;
			if (entry.comfort <= DISCOMFORT_THRESHOLD) flags.push(dim.id);
		}
		const responses: Record<string, string> = {};
		for (const q of ASSESSMENT_FREE_TEXT) responses[q.id] = String(form.get(q.id) ?? '').trim();
		const { data: goal } = await db.from('goals').select('id').eq('status', 'active').order('created_at', { ascending: false }).limit(1).maybeSingle();
		const { error } = await db.from('assessments').insert({
			goal_id: goal?.id ?? null,
			responses,
			scored_dimensions: scored,
			discomfort_flags: flags,
		});
		const status = document.querySelector<HTMLElement>('[data-assess-status]')!;
		status.textContent = error ? `Save failed: ${error.message}` : `Saved ✓ — ${flags.length} area(s) flagged to start from`;
		if (!error) {
			(document.querySelector('[data-assess-details]') as HTMLDetailsElement).open = false;
			loadAssessments();
		}
	});

	// -------------------------------------------------------------- Journey --
	const loadJourney = async () => {
		const { data } = await db
			.from('affirmations')
			.select('text,status,version,created_at')
			.neq('status', 'active')
			.order('created_at', { ascending: false })
			.limit(15);
		const CHIP: Record<string, string> = {
			internalized: 'border-emerald/60 text-emerald-glow',
			reshaped: 'border-mist/50 text-mist',
			retired: 'border-paper/30 text-paper/50',
		};
		const el = document.querySelector<HTMLElement>('[data-journey]')!;
		el.innerHTML = data?.length
			? data
					.map(
						(a) => `
			<li class="flex flex-wrap items-baseline gap-2 border-b border-paper/8 pb-2 text-sm">
				<span class="rounded-full border px-2 py-0.5 text-[10px] font-bold uppercase ${CHIP[a.status] ?? ''}">${esc(a.status)}</span>
				<span class="min-w-0 flex-1 text-paper/75">“${esc(a.text)}”</span>
				<span class="text-xs text-paper/40">v${a.version} · ${fmtDate(a.created_at)}</span>
			</li>`,
					)
					.join('')
			: '<li class="text-paper/55">Reshaped, internalized, and retired affirmations land here — the record of the road.</li>';
	};

	// ------------------------------------------------- Wins & reflections --
	const since = new Date(`${today}T00:00:00`);
	since.setDate(since.getDate() - 14);
	db.from('tasks')
		.select('title,completed_at,pillar')
		.eq('status', 'done')
		.gte('completed_at', since.toISOString())
		.order('completed_at', { ascending: false })
		.limit(20)
		.then(({ data }) => {
			const winsEl = document.querySelector<HTMLElement>('[data-wins]')!;
			winsEl.innerHTML = data?.length
				? data
						.map(
							(t) => `
				<li class="flex items-baseline gap-2.5">
					<span aria-hidden="true" class="text-emerald-glow">✓</span>
					<span>${esc(t.title)} <span class="text-xs text-paper/45">${t.completed_at ? fmtDate(t.completed_at) : ''}</span></span>
				</li>`,
						)
						.join('')
				: '<li class="text-paper/55">Close a task and it lands here.</li>';
		});

	db.from('daily_checkins')
		.select('date,reflection')
		.not('reflection', 'is', null)
		.order('date', { ascending: false })
		.limit(10)
		.then(({ data }) => {
			const reflEl = document.querySelector<HTMLElement>('[data-reflections]')!;
			reflEl.innerHTML = data?.length
				? data
						.map(
							(c) => `
				<li class="border-l-2 border-emerald/40 pl-4">
					<p class="leading-relaxed text-paper/85">${esc(c.reflection)}</p>
					<p class="mt-1 text-xs text-paper/45">${fmtDate(c.date)}</p>
				</li>`,
						)
						.join('')
				: '<li class="text-paper/55">Evening reflections from your daily check-ins show up here.</li>';
		});

	// ---------------------------------------------------------- Memory --
	type Memory = { id: string; content: string; kind: string; source: string; created_at: string };

	const memListEl = document.querySelector<HTMLElement>('[data-mem-list]')!;
	const memCountEl = document.querySelector<HTMLElement>('[data-mem-count]')!;
	const memErrorEl = document.querySelector<HTMLElement>('[data-mem-error]')!;
	const memSearchEl = document.querySelector<HTMLInputElement>('[data-mem-search]')!;
	const memDialog = document.querySelector<HTMLDialogElement>('[data-mem-dialog]')!;
	const memForm = document.querySelector<HTMLFormElement>('[data-mem-form]')!;
	const memDialogTitle = document.querySelector<HTMLElement>('[data-mem-dialog-title]')!;

	let editingMemId: string | null = null;

	const KIND_LABELS: Record<string, string> = {
		fact: 'Fact',
		preference: 'Preference',
		decision: 'Decision',
		person: 'Person',
		project_context: 'Project',
		conversation_summary: 'From chat',
	};

	const memError = (msg: string | null) => {
		memErrorEl.textContent = msg ?? '';
		memErrorEl.hidden = !msg;
	};

	const memApi = async (action: string, payload: Record<string, unknown> = {}) =>
		fnCall('maverick-memory', { action, ...payload });

	const renderMemories = (memories: Memory[], searching = false) => {
		if (!searching) memCountEl.textContent = `${memories.length} ${memories.length === 1 ? 'memory' : 'memories'}`;
		memListEl.innerHTML = memories.length
			? memories
					.map(
						(m) => `
			<li class="rounded-2xl bg-graphite p-5">
				<div class="flex flex-wrap items-start justify-between gap-3">
					<p class="min-w-0 flex-1 text-sm leading-relaxed text-paper/90">${esc(m.content)}</p>
					<div class="flex shrink-0 gap-1.5">
						<button type="button" data-mem-edit="${esc(m.id)}" aria-label="Edit memory" class="cursor-pointer rounded-full border border-paper/25 px-3 py-1 text-xs font-bold hover:border-emerald-glow hover:text-emerald-glow">Edit</button>
						<button type="button" data-mem-forget="${esc(m.id)}" aria-label="Forget memory" class="cursor-pointer rounded-full border border-terracotta/50 px-3 py-1 text-xs font-bold text-terracotta hover:bg-terracotta hover:text-ink">Forget</button>
					</div>
				</div>
				<p class="mt-2 flex flex-wrap items-center gap-2 text-[11px] text-paper/45">
					<span class="rounded-full bg-emerald-deep/40 px-2 py-0.5 font-bold text-emerald-glow uppercase">${esc(KIND_LABELS[m.kind] ?? m.kind)}</span>
					<span>${esc(m.source)}</span>
					<span>·</span>
					<span>${fmtDate(m.created_at)}</span>
				</p>
			</li>`,
					)
					.join('')
			: `<li class="text-paper/55">${searching ? 'Nothing matched — try different words.' : 'Nothing yet. Maverick learns as you chat, or add a memory by hand.'}</li>`;

		memListEl.querySelectorAll<HTMLButtonElement>('[data-mem-edit]').forEach((btn) =>
			btn.addEventListener('click', () => openMemDialog(memories.find((m) => m.id === btn.dataset.memEdit) ?? null)),
		);
		memListEl.querySelectorAll<HTMLButtonElement>('[data-mem-forget]').forEach((btn) =>
			btn.addEventListener('click', async () => {
				if (!confirm('Forget this memory? Maverick will no longer recall it.')) return;
				try {
					await memApi('forget', { id: btn.dataset.memForget });
					loadMemories();
				} catch (err) {
					memError(err instanceof Error ? err.message : 'Could not forget.');
				}
			}),
		);
	};

	const loadMemories = async () => {
		memError(null);
		memSearchEl.value = '';
		const { data, error } = await db
			.from('maverick_memories')
			.select('id,content,kind,source,created_at')
			.order('created_at', { ascending: false })
			.limit(200);
		if (error) {
			memError(`Could not load memories: ${error.message}`);
			return;
		}
		renderMemories((data ?? []) as Memory[]);
	};

	let searchTimer: ReturnType<typeof setTimeout>;
	memSearchEl.addEventListener('input', () => {
		clearTimeout(searchTimer);
		const q = memSearchEl.value.trim();
		if (!q) {
			loadMemories();
			return;
		}
		searchTimer = setTimeout(async () => {
			try {
				const hits = (await memApi('recall', { query: q, count: 15 })) as (Memory & { similarity: number })[];
				renderMemories(hits, true);
				memCountEl.textContent = `${hits.length} match${hits.length === 1 ? '' : 'es'}`;
			} catch (err) {
				memError(err instanceof Error ? err.message : 'Search failed.');
			}
		}, 350);
	});

	const openMemDialog = (memory: Memory | null) => {
		editingMemId = memory?.id ?? null;
		memDialogTitle.textContent = memory ? 'Edit memory' : 'Add memory';
		memForm.reset();
		(memForm.elements.namedItem('content') as HTMLTextAreaElement).value = memory?.content ?? '';
		(memForm.elements.namedItem('kind') as HTMLSelectElement).value = memory?.kind ?? 'fact';
		memDialog.showModal();
	};

	document.querySelector('[data-mem-add]')?.addEventListener('click', () => openMemDialog(null));

	memForm.addEventListener('submit', async (e) => {
		if ((e.submitter as HTMLButtonElement | null)?.value !== 'save') return;
		e.preventDefault();
		const content = (memForm.elements.namedItem('content') as HTMLTextAreaElement).value.trim();
		const kind = (memForm.elements.namedItem('kind') as HTMLSelectElement).value;
		if (!content) return;
		try {
			if (editingMemId) await memApi('update', { id: editingMemId, content, kind });
			else {
				const result = (await memApi('remember', { content, kind, source: 'manual' })) as { duplicate?: boolean };
				if (result?.duplicate) memError('Maverick already knew something almost identical — kept the existing one.');
			}
			memDialog.close();
			loadMemories();
		} catch (err) {
			memError(err instanceof Error ? err.message : 'Could not save.');
		}
	});

	// ------------------------------------------------------ Elevate wizard --
	const wizard = initElevateWizard(db, {
		onComplete: async () => {
			await loadRitual();
			loadDestination();
			loadNoticed();
			loadActiveSet();
			loadEvening();
			loadJourney();
		},
	});
	document.querySelector('[data-dest-restart]')!.addEventListener('click', () => wizard.open());

	// ------------------------------------------------------------- Boot --
	await loadRitual();
	loadDestination();
	loadNoticed();
	loadActiveSet();
	loadEvening();
	loadAssessments();
	loadJourney();
	loadMemories();
</script>
