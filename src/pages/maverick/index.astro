---
import MaverickLayout from '../../layouts/MaverickLayout.astro';

/**
 * Command Center Home — answers "what needs my attention today?" from the DB:
 * AI daily briefing (maverick-agent), top 3, active affirmation, daily
 * check-in, and an at-a-glance strip. See CLAUDE.md → Maverick Command Center.
 */
---

<MaverickLayout title="Maverick — Home" active="home">
	<h1 class="text-display-sm mt-8" data-home-date>Today.</h1>

	<!-- At-a-glance strip -->
	<dl class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-4" data-home-stats>
		{
			[
				{ id: 'overdue', label: 'Overdue tasks' },
				{ id: 'stalled', label: 'Stalled projects' },
				{ id: 'inquiries', label: 'New inquiries' },
				{ id: 'outstanding', label: 'Outstanding revenue' },
			].map((stat) => (
				<div class="rounded-2xl bg-graphite p-5">
					<dt class="text-xs font-semibold tracking-wide text-paper/55 uppercase">{stat.label}</dt>
					<dd class="mt-1 font-display text-3xl font-semibold" data-stat={stat.id}>
						—
					</dd>
				</div>
			))
		}
	</dl>

	<div class="mt-8 grid gap-6 lg:grid-cols-5">
		<div class="space-y-6 lg:col-span-3">
			<!-- Daily briefing -->
			<section class="rounded-2xl border border-emerald/30 bg-graphite p-6" aria-labelledby="briefing-h">
				<div class="flex items-center justify-between gap-4">
					<h2 id="briefing-h" class="text-eyebrow text-emerald-glow">Daily briefing</h2>
					<button
						type="button"
						data-briefing-refresh
						class="cursor-pointer rounded-full border border-paper/25 px-4 py-1.5 text-xs font-bold hover:border-emerald-glow hover:text-emerald-glow"
					>
						Regenerate
					</button>
				</div>
				<div class="mt-4 space-y-3 text-[15px] leading-relaxed text-paper/85" data-briefing aria-live="polite">
					<p class="text-paper/55">Loading…</p>
				</div>
			</section>

			<!-- Top tasks -->
			<section class="rounded-2xl bg-graphite p-6" aria-labelledby="top-h">
				<h2 id="top-h" class="text-eyebrow text-mist">Top of the list</h2>
				<ul class="mt-4 space-y-3" data-top-tasks>
					<li class="text-paper/55">Loading…</li>
				</ul>
				<a href="/maverick/projects" class="mt-5 inline-block text-sm font-semibold text-emerald-glow hover:underline">All projects & tasks →</a>
			</section>
		</div>

		<div class="space-y-6 lg:col-span-2">
			<!-- Active affirmation -->
			<section class="rounded-2xl bg-emerald-deep/25 p-6" aria-labelledby="affirmation-h">
				<h2 id="affirmation-h" class="text-eyebrow text-emerald-glow">Today's affirmation</h2>
				<blockquote class="mt-3 font-display text-xl leading-snug font-medium" data-affirmation>—</blockquote>
			</section>

			<!-- Daily check-in -->
			<section class="rounded-2xl bg-graphite p-6" aria-labelledby="checkin-h">
				<h2 id="checkin-h" class="text-eyebrow text-mist">Daily check-in</h2>
				<form data-checkin class="mt-4 space-y-4">
					{
						[
							{ id: 'most_important', label: 'Most important thing today' },
							{ id: 'avoiding', label: "What I'm avoiding" },
							{ id: 'success_looks_like', label: 'Success today looks like' },
							{ id: 'gratitude', label: 'Grateful for' },
							{ id: 'reflection', label: 'Evening reflection' },
						].map((f) => (
							<div>
								<label for={`ci-${f.id}`} class="block text-sm font-semibold">
									{f.label}
								</label>
								<textarea
									id={`ci-${f.id}`}
									name={f.id}
									rows="2"
									class="mt-1.5 w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 text-sm text-paper focus:border-emerald"
								/>
							</div>
						))
					}
					<div class="flex items-center gap-4">
						<button type="submit" class="cursor-pointer rounded-full bg-emerald px-6 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105">
							Save check-in
						</button>
						<p class="text-sm text-emerald-glow" data-checkin-status role="status"></p>
					</div>
				</form>
			</section>
		</div>
	</div>
</MaverickLayout>

<script>
	import {
		initMaverick,
		invokeAgent,
		esc,
		fmtMoney,
		fmtDate,
		todayISO,
		priorityScore,
		renderMarkdown,
		PILLAR_LABELS,
	} from '../../lib/maverick/client';

	const db = await initMaverick();
	const today = todayISO();

	document.querySelector('[data-home-date]')!.textContent = new Intl.DateTimeFormat('en-US', {
		weekday: 'long',
		month: 'long',
		day: 'numeric',
	}).format(new Date());

	const briefingEl = document.querySelector<HTMLElement>('[data-briefing]')!;
	const stat = (id: string) => document.querySelector<HTMLElement>(`[data-stat="${id}"]`)!;

	// --- Briefing: show today's, generate it if it doesn't exist yet ---
	const showBriefing = (content: string) => {
		briefingEl.innerHTML = renderMarkdown(content);
	};

	const generateBriefing = async () => {
		briefingEl.innerHTML = '<p class="text-paper/55">Maverick is reading the board…</p>';
		try {
			const { content } = await invokeAgent<{ content: string }>(db, 'daily_briefing');
			showBriefing(content);
		} catch (err) {
			briefingEl.innerHTML = `<p class="text-terracotta">${esc(err instanceof Error ? err.message : 'Briefing failed.')}</p>`;
		}
	};

	db.from('daily_briefings')
		.select('content')
		.eq('date', today)
		.maybeSingle()
		.then(({ data }) => (data ? showBriefing(data.content) : generateBriefing()));

	document.querySelector('[data-briefing-refresh]')?.addEventListener('click', generateBriefing);

	// --- At-a-glance stats ---
	const loadStats = async () => {
		const [overdue, stalled, inquiries, revenue] = await Promise.all([
			db.from('tasks').select('id', { count: 'exact', head: true }).neq('status', 'done').lt('due_date', today),
			db.from('projects').select('id', { count: 'exact', head: true }).eq('status', 'stalled'),
			db.from('inquiries').select('id', { count: 'exact', head: true }).eq('status', 'new'),
			db.from('revenue_items').select('amount').neq('status', 'paid'),
		]);
		stat('overdue').textContent = String(overdue.count ?? 0);
		stat('overdue').classList.toggle('text-terracotta', (overdue.count ?? 0) > 0);
		stat('stalled').textContent = String(stalled.count ?? 0);
		stat('inquiries').textContent = String(inquiries.count ?? 0);
		stat('outstanding').textContent = fmtMoney((revenue.data ?? []).reduce((sum, r) => sum + Number(r.amount), 0));
	};
	loadStats();

	// --- Top tasks (priority-scored) ---
	const topList = document.querySelector<HTMLElement>('[data-top-tasks]')!;
	const loadTop = async () => {
		const { data } = await db
			.from('tasks')
			.select('id,title,priority,due_date,pillar,impact_score,urgency_score')
			.neq('status', 'done')
			.limit(60);
		const top = (data ?? []).sort((a, b) => priorityScore(b) - priorityScore(a)).slice(0, 5);
		topList.innerHTML = top.length
			? top
					.map(
						(t) => `
				<li class="flex items-start gap-3">
					<input type="checkbox" id="top-${esc(t.id)}" data-done="${esc(t.id)}" class="mt-1 h-4 w-4 accent-emerald" />
					<label for="top-${esc(t.id)}" class="cursor-pointer text-sm leading-snug">
						${esc(t.title)}
						<span class="mt-0.5 block text-xs text-paper/50">${esc(PILLAR_LABELS[t.pillar])}${t.due_date ? ` · due ${fmtDate(t.due_date)}` : ''}</span>
					</label>
				</li>`,
					)
					.join('')
			: '<li class="text-paper/55">Nothing open. Add tasks under Projects.</li>';

		topList.querySelectorAll<HTMLInputElement>('[data-done]').forEach((box) => {
			box.addEventListener('change', async () => {
				if (!box.checked) return;
				await db.from('tasks').update({ status: 'done', completed_at: new Date().toISOString() }).eq('id', box.dataset.done!);
				loadTop();
				loadStats();
			});
		});
	};
	loadTop();

	// --- Active affirmation ---
	db.from('affirmations')
		.select('text')
		.eq('active', true)
		.limit(1)
		.maybeSingle()
		.then(({ data }) => {
			document.querySelector('[data-affirmation]')!.textContent = data?.text ?? 'No active affirmation — evolve one on the Growth page.';
		});

	// --- Daily check-in ---
	const form = document.querySelector<HTMLFormElement>('[data-checkin]')!;
	const statusEl = document.querySelector<HTMLElement>('[data-checkin-status]')!;
	const FIELDS = ['most_important', 'avoiding', 'success_looks_like', 'gratitude', 'reflection'] as const;

	db.from('daily_checkins')
		.select('*')
		.eq('date', today)
		.maybeSingle()
		.then(({ data }) => {
			if (!data) return;
			for (const f of FIELDS) {
				const el = form.elements.namedItem(f) as HTMLTextAreaElement | null;
				if (el) el.value = data[f] ?? '';
			}
		});

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		const values = Object.fromEntries(
			FIELDS.map((f) => [f, (form.elements.namedItem(f) as HTMLTextAreaElement).value.trim() || null]),
		);
		const { error } = await db.from('daily_checkins').upsert({ date: today, ...values }, { onConflict: 'date' });
		statusEl.textContent = error ? `Save failed: ${error.message}` : 'Saved ✓';
		statusEl.classList.toggle('text-terracotta', !!error);
		setTimeout(() => (statusEl.textContent = ''), 2500);
	});
</script>
