---
import MaverickLayout from '../../layouts/MaverickLayout.astro';

const LIST_FIELDS = [
	{ id: 'wins', label: 'Wins', rows: 4 },
	{ id: 'projects_advanced', label: 'Projects advanced', rows: 3 },
	{ id: 'projects_stalled', label: 'Projects stalled', rows: 3 },
	{ id: 'missed_followups', label: 'Missed follow-ups', rows: 3 },
	{ id: 'next_top3', label: "Next week's top 3", rows: 3 },
];
---

<MaverickLayout title="Maverick — Weekly Review" active="review">
	<div class="mt-8 flex flex-wrap items-center justify-between gap-4">
		<h1 class="text-display-sm">Weekly review.</h1>
		<button
			type="button"
			data-rev-generate
			class="cursor-pointer rounded-full bg-emerald px-6 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105"
		>
			Generate draft
		</button>
	</div>
	<p class="mt-3 text-paper/60" data-rev-week>Week of —</p>
	<p class="mt-2 text-sm text-terracotta" data-rev-error role="alert" hidden></p>

	<form data-review-form class="mt-6 rounded-3xl bg-graphite p-7">
		<p class="text-xs text-paper/50">One item per line in the list fields — Maverick drafts, you edit, then save.</p>
		<div class="mt-5 grid gap-5 md:grid-cols-2">
			{
				LIST_FIELDS.map((f) => (
					<div class:list={[f.id === 'wins' && 'md:col-span-2']}>
						<label for={`wr-${f.id}`} class="block text-sm font-semibold">
							{f.label}
						</label>
						<textarea
							id={`wr-${f.id}`}
							name={f.id}
							rows={f.rows}
							class="mt-1.5 w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 text-sm text-paper focus:border-emerald"
						/>
					</div>
				))
			}
			<div>
				<label for="wr-revenue" class="block text-sm font-semibold">Revenue movement</label>
				<textarea id="wr-revenue" name="revenue_movement" rows="3" class="mt-1.5 w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 text-sm text-paper focus:border-emerald"></textarea>
			</div>
			<div>
				<label for="wr-lessons" class="block text-sm font-semibold">Lessons</label>
				<textarea id="wr-lessons" name="lessons" rows="3" class="mt-1.5 w-full rounded-lg border border-paper/20 bg-ink px-3 py-2 text-sm text-paper focus:border-emerald"></textarea>
			</div>
		</div>
		<div class="mt-6 flex items-center gap-4">
			<button type="submit" class="cursor-pointer rounded-full bg-emerald px-7 py-2.5 text-sm font-bold text-ink transition-transform hover:scale-105">
				Save review
			</button>
			<p class="text-sm text-emerald-glow" data-rev-status role="status"></p>
		</div>
	</form>

	<!-- Past reviews -->
	<h2 class="text-eyebrow mt-12 text-mist">Past reviews</h2>
	<div class="mt-4 space-y-4" data-rev-past>
		<p class="text-paper/55">Loading…</p>
	</div>
</MaverickLayout>

<script>
	import { initMaverick, invokeAgent, esc, fmtDate, todayISO } from '../../lib/maverick/client';
	import type { Tables } from '../../lib/maverick/db-types';

	type Review = Tables<'weekly_reviews'>;

	const db = await initMaverick();

	// Monday of the current week (local) — mirrors the edge function's logic
	const monday = (() => {
		const d = new Date(`${todayISO()}T00:00:00Z`);
		d.setUTCDate(d.getUTCDate() - ((d.getUTCDay() + 6) % 7));
		return d.toISOString().slice(0, 10);
	})();

	document.querySelector('[data-rev-week]')!.textContent = `Week of ${fmtDate(monday)}`;

	const form = document.querySelector<HTMLFormElement>('[data-review-form]')!;
	const statusEl = document.querySelector<HTMLElement>('[data-rev-status]')!;
	const errorEl = document.querySelector<HTMLElement>('[data-rev-error]')!;
	const generateBtn = document.querySelector<HTMLButtonElement>('[data-rev-generate]')!;
	const pastEl = document.querySelector<HTMLElement>('[data-rev-past]')!;

	const LIST_FIELDS = ['wins', 'projects_advanced', 'projects_stalled', 'missed_followups', 'next_top3'] as const;
	const TEXT_FIELDS = ['revenue_movement', 'lessons'] as const;

	const field = (name: string) => form.elements.namedItem(name) as HTMLTextAreaElement;
	const asLines = (v: unknown): string => (Array.isArray(v) ? v.map(String).join('\n') : '');

	const fillForm = (review: Review | null) => {
		for (const f of LIST_FIELDS) field(f).value = asLines(review?.[f]);
		for (const f of TEXT_FIELDS) field(f).value = review?.[f] ?? '';
	};

	const loadCurrent = async () => {
		const { data } = await db.from('weekly_reviews').select('*').eq('week_start', monday).maybeSingle();
		fillForm(data);
	};

	const loadPast = async () => {
		const { data } = await db
			.from('weekly_reviews')
			.select('*')
			.neq('week_start', monday)
			.order('week_start', { ascending: false })
			.limit(12);
		const section = (title: string, items: unknown) =>
			Array.isArray(items) && items.length
				? `<p class="mt-2 text-sm"><span class="font-semibold text-emerald-glow">${title}:</span> ${items.map((i) => esc(i)).join(' · ')}</p>`
				: '';
		pastEl.innerHTML = data?.length
			? data
					.map(
						(r) => `
			<details class="rounded-2xl bg-graphite p-6">
				<summary class="cursor-pointer list-none font-display text-lg font-semibold [&::-webkit-details-marker]:hidden">
					Week of ${fmtDate(r.week_start)}
				</summary>
				${section('Wins', r.wins)}
				${r.revenue_movement ? `<p class="mt-2 text-sm"><span class="font-semibold text-emerald-glow">Revenue:</span> ${esc(r.revenue_movement)}</p>` : ''}
				${section('Advanced', r.projects_advanced)}
				${section('Stalled', r.projects_stalled)}
				${section('Missed follow-ups', r.missed_followups)}
				${r.lessons ? `<p class="mt-2 text-sm"><span class="font-semibold text-emerald-glow">Lessons:</span> ${esc(r.lessons)}</p>` : ''}
				${section('Top 3 set for the next week', r.next_top3)}
			</details>`,
					)
					.join('')
			: '<p class="text-paper/55">Your first saved review starts the archive.</p>';
	};

	generateBtn.addEventListener('click', async () => {
		errorEl.hidden = true;
		generateBtn.disabled = true;
		generateBtn.textContent = 'Maverick is reviewing the week…';
		try {
			const review = await invokeAgent<Review>(db, 'weekly_review');
			fillForm(review);
			statusEl.textContent = 'Draft ready — edit and save.';
			setTimeout(() => (statusEl.textContent = ''), 4000);
		} catch (err) {
			errorEl.textContent = err instanceof Error ? err.message : 'Draft failed.';
			errorEl.hidden = false;
		} finally {
			generateBtn.disabled = false;
			generateBtn.textContent = 'Generate draft';
		}
	});

	form.addEventListener('submit', async (e) => {
		e.preventDefault();
		const lines = (name: string) =>
			field(name)
				.value.split('\n')
				.map((l) => l.trim())
				.filter(Boolean);
		const { error } = await db.from('weekly_reviews').upsert(
			{
				week_start: monday,
				wins: lines('wins'),
				projects_advanced: lines('projects_advanced'),
				projects_stalled: lines('projects_stalled'),
				missed_followups: lines('missed_followups'),
				next_top3: lines('next_top3'),
				revenue_movement: field('revenue_movement').value.trim() || null,
				lessons: field('lessons').value.trim() || null,
			},
			{ onConflict: 'week_start' },
		);
		statusEl.textContent = error ? `Save failed: ${error.message}` : 'Saved ✓';
		statusEl.classList.toggle('text-terracotta', !!error);
		setTimeout(() => (statusEl.textContent = ''), 2500);
		loadPast();
	});

	loadCurrent();
	loadPast();
</script>
