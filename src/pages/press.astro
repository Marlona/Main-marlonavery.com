---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { SITE_CONFIG } from '../config';
import { PODCAST } from '../data/podcast';

import headshot from '../assets/photos/portrait-1.jpg';
import stageLecture from '../assets/photos/stage-1.jpg';
import actionShot from '../assets/photos/workshop-floor-facilitation.jpg';

const press = (await getCollection('press'))[0];
const bios = press?.data.bios ?? [];
const pressTopics = press?.data.topics ?? [];

const pressPhotos = [
	{ src: headshot, label: 'Headshot', file: '/press/marlon-avery-headshot.jpg', alt: 'Marlon Avery panel-stage headshot' },
	{ src: stageLecture, label: 'Speaking', file: '/press/marlon-avery-speaking.jpg', alt: 'Marlon Avery speaking from a lectern' },
	{ src: actionShot, label: 'Action shot', file: '/press/marlon-avery-action.jpg', alt: 'Marlon Avery coaching a workshop participant' },
];
---

<BaseLayout
	title="Speaking & Press Kit"
	description="Everything event planners and media need to book Marlon Avery — bios, photos, talk topics, the AI With Friends podcast, and booking contacts."
>
	<div class="bg-paper px-6 pt-36 pb-16 md:pt-44">
		<div class="mx-auto max-w-7xl">
			<p class="text-eyebrow reveal text-emerald-deep">Speaking & press kit</p>
			<h1 class="text-display-lg reveal mt-6 max-w-4xl">Everything you need to say yes.</h1>
			<p class="reveal mt-8 max-w-2xl text-lg leading-relaxed text-slate">
				Copy-ready bios, downloadable photography, talk topics, and booking contacts — built for event
				planners, emcees, and media.
			</p>
		</div>
	</div>

	<Section pad="compact">
		<!-- Bios with copy buttons -->
		<div class="grid gap-6 lg:grid-cols-3">
			{
				bios.map((bio) => (
					<div class="reveal flex flex-col rounded-2xl bg-cream p-8">
						<div class="flex items-center justify-between gap-4">
							<h2 class="text-eyebrow text-emerald-deep">{bio.label}</h2>
							<button
								type="button"
								class="cursor-pointer rounded-full border border-ink/20 px-4 py-1.5 text-xs font-bold transition-colors hover:border-emerald-deep hover:text-emerald-deep"
								data-copy-bio
								data-copy-text={bio.content}
							>
								Copy
							</button>
						</div>
						<p class="mt-4 text-sm leading-relaxed text-ink/85">{bio.content}</p>
						<p class="mt-auto pt-4 text-xs text-slate">{bio.wordCount} words</p>
					</div>
				))
			}
		</div>

		<!-- Photos with download buttons -->
		<h2 class="reveal mt-16 mb-6 font-display text-2xl font-semibold">Photos</h2>
		<div class="grid gap-6 md:grid-cols-3">
			{
				pressPhotos.map((photo) => (
					<figure class="reveal overflow-hidden rounded-2xl bg-cream">
						<Image
							src={photo.src}
							alt={photo.alt}
							widths={[480, 800]}
							sizes="(max-width: 768px) 100vw, 33vw"
							class="aspect-[4/3] w-full object-cover"
						/>
						<figcaption class="flex items-center justify-between gap-4 p-5">
							<span class="font-semibold">{photo.label}</span>
							<a
								href={photo.file}
								download
								class="rounded-full bg-ink px-5 py-2 text-sm font-bold text-paper transition-colors hover:bg-emerald-deep"
							>
								Download ↓
							</a>
						</figcaption>
					</figure>
				))
			}
		</div>

		<!-- Talk topics -->
		<h2 class="reveal mt-16 mb-6 font-display text-2xl font-semibold">Talk topics</h2>
		<ul class="grid gap-x-12 md:grid-cols-2">
			{
				pressTopics.map((topic) => (
					<li class="reveal border-b border-ink/10 py-4">
						<div class="flex flex-wrap items-baseline justify-between gap-2">
							<p class="font-semibold">{topic.title}</p>
							<span class="text-xs font-semibold text-slate">{topic.duration}</span>
						</div>
						<p class="mt-1 text-sm text-slate">{topic.abstract}</p>
					</li>
				))
			}
		</ul>
		<a href="/speaking" class="reveal mt-6 inline-block font-semibold text-emerald-deep hover:underline">
			Full keynote catalog →
		</a>

		<!-- Podcast -->
		<div class="reveal mt-16 rounded-3xl bg-ink p-8 text-paper md:p-12">
			<p class="text-eyebrow text-emerald-glow">The podcast</p>
			<h2 class="mt-3 font-display text-3xl font-semibold">{PODCAST.name}</h2>
			<p class="mt-3 max-w-2xl leading-relaxed text-paper/75">{PODCAST.tagline}</p>
			<div class="mt-6 flex flex-wrap gap-3">
				{
					PODCAST.platforms.map((platform) => (
						<a
							href={platform.url}
							rel="noopener"
							class="rounded-full border border-paper/30 px-5 py-2.5 text-sm font-semibold transition-colors hover:border-emerald-glow hover:text-emerald-glow"
						>
							Listen on {platform.label}
						</a>
					))
				}
			</div>
			<h3 class="text-eyebrow mt-8 text-mist">Co-hosts</h3>
			<ul class="mt-4 grid gap-4 md:grid-cols-3">
				{
					PODCAST.cohosts.map((host) => (
						<li class="rounded-xl bg-graphite p-5">
							<p class="font-semibold">{host.name}</p>
							<p class="mt-1 text-sm text-paper/60">{host.title}</p>
						</li>
					))
				}
			</ul>
		</div>

		<!-- Booking CTA -->
		<div class="reveal mt-16 rounded-3xl border-2 border-emerald/40 bg-cream p-8 text-center md:p-12">
			<h2 class="font-display text-3xl font-semibold">Interested in having Marlon speak?</h2>
			<p class="mx-auto mt-3 max-w-xl text-slate">
				Get in touch with the details about your conference, audience, and the moment you're planning.
			</p>
			<div class="mt-8 flex flex-wrap justify-center gap-4">
				<a href="/speaking#booking-form" class="rounded-full bg-ink px-8 py-4 font-semibold text-paper transition-colors hover:bg-emerald-deep">
					Speaker inquiry →
				</a>
				<a
					href={`mailto:${SITE_CONFIG.email}?subject=Speaking+Inquiry`}
					class="rounded-full border border-ink/30 px-8 py-4 font-semibold transition-colors hover:border-emerald-deep hover:text-emerald-deep"
				>
					Email directly
				</a>
			</div>
		</div>
	</Section>

	<script>
		// Copy-to-clipboard for press kit bios, with inline confirmation.
		// Falls back to a hidden-textarea copy where the async clipboard API is unavailable.
		const copyText = async (text: string) => {
			try {
				await navigator.clipboard.writeText(text);
				return true;
			} catch {
				const ta = document.createElement('textarea');
				ta.value = text;
				ta.style.position = 'fixed';
				ta.style.opacity = '0';
				document.body.appendChild(ta);
				ta.select();
				// Deliberate use of the legacy API as a fallback where the async clipboard is blocked
				const legacy = document as unknown as { execCommand(command: string): boolean };
				const ok = legacy.execCommand('copy');
				ta.remove();
				return ok;
			}
		};

		for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-copy-bio]')) {
			btn.addEventListener('click', async () => {
				const ok = await copyText(btn.dataset.copyText ?? '');
				const original = btn.textContent;
				btn.textContent = ok ? 'Copied ✓' : 'Copy failed';
				btn.classList.add('border-emerald-deep', 'text-emerald-deep');
				setTimeout(() => {
					btn.textContent = original;
					btn.classList.remove('border-emerald-deep', 'text-emerald-deep');
				}, 1600);
			});
		}
	</script>
</BaseLayout>
