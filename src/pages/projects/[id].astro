---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import BrandWordmark from '../../components/BrandWordmark.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects', ({ data }) => !data.confidential);
	return projects.map((project) => ({
		params: { id: project.id },
		props: { project },
	}));
}

interface Props {
	project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);
const shortTitle = data.title.split('—')[0].trim();
---

<BaseLayout title={shortTitle} description={data.description.slice(0, 155)}>
	<div class="theme-fixed bg-ink px-6 pt-36 pb-20 text-paper md:pt-44">
		<div class="mx-auto max-w-7xl">
			<p class="text-eyebrow reveal text-emerald-glow">{data.role} · {data.organization}</p>
			<h1 class="text-display-md reveal mt-6 max-w-4xl">{shortTitle}</h1>
			<p class="reveal mt-6 max-w-3xl text-lg leading-relaxed text-paper/80">{data.impactSummary}</p>
			{
				data.partners.length > 0 && (
					<div class="reveal mt-8">
						<p class="text-eyebrow text-paper/60">In partnership with</p>
						<ul class="mt-4 flex flex-wrap items-center gap-3" aria-label="Partner organizations">
							{data.partners.map((name) => (
								<li class="rounded-xl bg-paper px-5 py-3 font-display text-lg font-semibold tracking-tight">
									<BrandWordmark name={name} />
								</li>
							))}
						</ul>
					</div>
				)
			}
			<ul class="reveal mt-8 flex flex-wrap gap-2" aria-label="Technologies">
				{
					data.primaryTech.map((tech) => (
						<li class="rounded-full bg-graphite px-3 py-1.5 text-xs font-medium text-mist">{tech}</li>
					))
				}
			</ul>
			{
				data.externalLink && (
					<a href={data.externalLink} rel="noopener" class="reveal mt-8 inline-block font-semibold text-emerald-glow hover:underline">
						Visit {new URL(data.externalLink).hostname} →
					</a>
				)
			}
		</div>
	</div>

	{
		data.videoUrl && (
			<div class="theme-fixed bg-ink px-6 pb-20 text-paper">
				<div class="mx-auto max-w-5xl">
					<h2 id="film" class="text-eyebrow reveal mb-5 text-emerald-glow">
						{data.videoTitle}
					</h2>
					{/* Click-to-play with native controls — no motion until asked for */}
					<video
						src={data.videoUrl}
						poster={data.videoPoster}
						controls
						preload="metadata"
						playsinline
						class="reveal aspect-video w-full rounded-2xl bg-graphite"
					>
						<p>
							Your browser can't play this video —
							<a href={data.videoUrl} class="text-emerald-glow underline">
								download it instead
							</a>
							.
						</p>
					</video>
				</div>
			</div>
		)
	}

	{
		data.cities.length > 0 && (
			<div class="theme-fixed bg-ink px-6 pb-16 text-paper">
				<div class="mx-auto max-w-5xl">
					<h2 class="text-eyebrow reveal text-emerald-glow">The footprint</h2>
					<p class="reveal mt-4 font-display text-3xl font-semibold md:text-4xl">
						{data.cities.length} cities and counting.
					</p>
					<ul class="reveal mt-6 flex flex-wrap gap-2" aria-label="Cities covered so far">
						{data.cities.map((city) => (
							<li class="rounded-full bg-graphite px-4 py-2 text-sm font-medium text-mist">{city}</li>
						))}
					</ul>
				</div>
			</div>
		)
	}

	{
		data.cityFilms.length > 0 && (
			<div class="theme-fixed bg-ink px-6 pb-24 text-paper">
				<div class="mx-auto max-w-5xl">
					<h2 class="text-eyebrow reveal mb-5 text-emerald-glow">City by city</h2>
					<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
						{data.cityFilms.map((film) => (
							<figure class="reveal">
								<YouTubeEmbed youtubeId={film.youtubeId} title={`${shortTitle} — ${film.city}`} />
								<figcaption class="mt-3 text-sm font-semibold text-paper/80">{film.city}</figcaption>
							</figure>
						))}
					</div>
				</div>
			</div>
		)
	}

	<Section>
		<div class="grid gap-16 lg:grid-cols-3">
			<div class="prose prose-lg max-w-none lg:col-span-2 prose-headings:font-display prose-a:text-emerald-deep">
				<Content />
			</div>

			<aside class="space-y-10 lg:sticky lg:top-24 lg:self-start">
				{
					data.contributions.length > 0 && (
						<div class="reveal">
							<h2 class="text-eyebrow text-emerald-deep">What Marlon built</h2>
							<ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate">
								{data.contributions.map((c) => (
									<li class="border-l-2 border-emerald/40 pl-4">{c}</li>
								))}
							</ul>
						</div>
					)
				}
				{
					data.outcomes.length > 0 && (
						<div class="reveal">
							<h2 class="text-eyebrow text-emerald-deep">Impact</h2>
							<ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate">
								{data.outcomes.map((o) => (
									<li class="flex gap-2">
										<span class="text-emerald-deep" aria-hidden="true">
											◆
										</span>
										{o}
									</li>
								))}
							</ul>
						</div>
					)
				}
				{
					data.lessonsLearned.length > 0 && (
						<div class="reveal">
							<h2 class="text-eyebrow text-emerald-deep">Lessons learned</h2>
							<ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate">
								{data.lessonsLearned.map((l) => (
									<li>{l}</li>
								))}
							</ul>
						</div>
					)
				}
			</aside>
		</div>
	</Section>

	<Section tone="dark" eyebrow="The flywheel" title="This build became a lesson.">
		<p class="reveal max-w-2xl text-lg text-paper/75">
			Every system Marlon ships turns into teachable patterns — in keynotes, workshops, and executive
			sessions. Want the lessons from this one, live?
		</p>
		<div class="reveal mt-8 flex flex-wrap gap-4">
			<a href="/speaking" class="rounded-full bg-emerald px-8 py-4 font-semibold text-ink transition-transform hover:scale-105">
				Book Marlon to Speak
			</a>
			<a href="/workshops" class="rounded-full border border-paper/40 px-8 py-4 font-semibold text-paper transition-colors hover:border-emerald-glow hover:text-emerald-glow">
				Explore Workshops
			</a>
		</div>
	</Section>
</BaseLayout>
