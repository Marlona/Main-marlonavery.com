---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects', ({ data }) => !data.confidential)).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf(),
);
---

<BaseLayout
	title="Projects"
	description="AI systems Marlon Avery has actually shipped — voice agents, document intelligence, agentic workflows, and the ventures built around them."
>
	<div class="theme-fixed bg-ink px-6 pt-36 pb-20 text-paper md:pt-44">
		<div class="mx-auto max-w-7xl">
			<p class="text-eyebrow reveal text-emerald-glow">The work</p>
			<h1 class="text-display-lg reveal mt-6 max-w-4xl">Built. Shipped. Taught.</h1>
			<p class="reveal mt-8 max-w-2xl text-lg leading-relaxed text-paper/80">
				Every case study here is a system that ran in production for real users — and every one of them
				became curriculum.
			</p>
		</div>
	</div>

	<Section tone="dark" class="pt-0 md:pt-0">
		<div class="grid gap-6 md:grid-cols-2">
			{
				projects.map((project) => (
					<ProjectCard
						href={`/projects/${project.id}`}
						title={project.data.title.split('—')[0].trim()}
						description={project.data.description}
						impact={project.data.impactSummary}
						tech={project.data.primaryTech}
					/>
				))
			}
		</div>
	</Section>

	<Section eyebrow="The flywheel" title="Want the lessons behind these builds?">
		<div class="reveal flex flex-wrap gap-4">
			<a href="/workshops" class="rounded-full bg-ink px-8 py-4 font-semibold text-paper transition-colors hover:bg-emerald-deep">
				Learn in a workshop
			</a>
			<a href="/speaking" class="rounded-full border border-ink/30 px-8 py-4 font-semibold transition-colors hover:border-emerald-deep hover:text-emerald-deep">
				Book the keynote version
			</a>
		</div>
	</Section>
</BaseLayout>
