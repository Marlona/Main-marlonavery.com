---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Testimonial from '../../components/Testimonial.astro';
import BookingForm from '../../components/BookingForm.astro';

export async function getStaticPaths() {
	const workshops = await getCollection('workshops');
	return workshops.map((workshop) => ({
		params: { id: workshop.id },
		props: { workshop },
	}));
}

interface Props {
	workshop: CollectionEntry<'workshops'>;
}

const { workshop } = Astro.props;
const { data } = workshop;
---

<BaseLayout title={data.title} description={`${data.tagline}. ${data.duration}, ${data.format} — an AI workshop by Marlon Avery.`}>
	<div class="theme-fixed bg-ink px-6 pt-36 pb-20 text-paper md:pt-44">
		<div class="mx-auto max-w-7xl">
			<p class="text-eyebrow reveal text-emerald-glow">
				{data.level} · {data.format} · {data.duration}
			</p>
			<h1 class="text-display-lg reveal mt-6 max-w-4xl">{data.title}</h1>
			<p class="reveal mt-6 max-w-2xl text-xl text-paper/80">{data.tagline}</p>
			<a
				href="#book"
				class="reveal mt-10 inline-block rounded-full bg-emerald px-8 py-4 font-semibold text-ink transition-transform hover:scale-105"
			>
				Bring this to my team
			</a>
		</div>
	</div>

	<Section>
		<div class="grid gap-16 lg:grid-cols-3">
			<div class="lg:col-span-2">
				{data.description && <p class="reveal text-lg leading-relaxed text-slate">{data.description}</p>}

				{
					data.curriculum.length > 0 && (
						<div class="mt-14">
							<h2 class="text-display-sm reveal">The curriculum</h2>
							<ol class="mt-8 space-y-4">
								{data.curriculum.map((item, i) => (
									<li class="reveal flex gap-6 rounded-2xl bg-cream p-6">
										<span class="font-display text-3xl font-semibold text-emerald-deep">{String(i + 1).padStart(2, '0')}</span>
										<div>
											<h3 class="font-display text-xl font-semibold">{item.module}</h3>
											<p class="mt-1 leading-relaxed text-slate">{item.summary}</p>
										</div>
									</li>
								))}
							</ol>
						</div>
					)
				}

				{
					data.outcomes.length > 0 && (
						<div class="mt-14">
							<h2 class="text-display-sm reveal">You will leave able to…</h2>
							<ul class="mt-6 space-y-3">
								{data.outcomes.map((outcome) => (
									<li class="reveal flex gap-3 text-lg text-slate">
										<span class="text-emerald-deep" aria-hidden="true">
											◆
										</span>
										{outcome}
									</li>
								))}
							</ul>
						</div>
					)
				}
			</div>

			<aside class="space-y-8 lg:sticky lg:top-24 lg:self-start">
				<div class="reveal rounded-2xl border border-ink/10 bg-paper p-6 shadow-lg">
					<h2 class="text-eyebrow text-emerald-deep">At a glance</h2>
					<dl class="mt-4 space-y-3 text-sm">
						<div class="flex justify-between gap-4">
							<dt class="font-semibold">Level</dt>
							<dd class="capitalize text-slate">{data.level}</dd>
						</div>
						<div class="flex justify-between gap-4">
							<dt class="font-semibold">Format</dt>
							<dd class="capitalize text-slate">{data.format}</dd>
						</div>
						<div class="flex justify-between gap-4">
							<dt class="font-semibold">Duration</dt>
							<dd class="text-slate">{data.duration}</dd>
						</div>
					</dl>
					<h3 class="text-eyebrow mt-6 text-emerald-deep">Who it's for</h3>
					<ul class="mt-3 space-y-1.5 text-sm text-slate">
						{data.audience.map((a) => <li>{a}</li>)}
					</ul>
					{
						data.deliverables.length > 0 && (
							<>
								<h3 class="text-eyebrow mt-6 text-emerald-deep">You take home</h3>
								<ul class="mt-3 space-y-1.5 text-sm text-slate">
									{data.deliverables.map((d) => <li>· {d}</li>)}
								</ul>
							</>
						)
					}
				</div>

				{
					data.industries.length > 0 && (
						<div class="reveal">
							<h2 class="text-eyebrow text-emerald-deep">Designed for all industries, including</h2>
							<ul class="mt-3 flex flex-wrap gap-2">
								{data.industries.map((industry) => (
									<li class="rounded-full bg-cream px-3 py-1.5 text-xs font-medium text-slate">{industry}</li>
								))}
								<li class="rounded-full border border-dashed border-slate/40 px-3 py-1.5 text-xs font-medium text-slate">+ yours</li>
							</ul>
						</div>
					)
				}
			</aside>
		</div>

		{
			data.testimonials.length > 0 && (
				<div class="mt-20 grid gap-6 md:grid-cols-2">
					{data.testimonials.map((t) => (
						<Testimonial quote={t.quote} name={t.name} title={t.title} org={t.org} />
					))}
				</div>
			)
		}
	</Section>

	<Section tone="dark" id="book" eyebrow="Next step" title="Bring this workshop to your team.">
		<BookingForm heading={`Book: ${data.title}`} kind="workshop" />
	</Section>
</BaseLayout>
